using { com.scb.fileupload.master as db } from '../db/schema';

service MFUService {

    entity ReportFileStorage as projection on db.ReportFileStorage;
    entity TemplateStorage as projection on db.TemplateStorage;

    function getModules() returns array of {
        module : String;
    };

    function getDashboardData(module : array of String) returns {
        uploaded        : Integer;
        approved        : Integer;
        rejected        : Integer;
        totalTemplates  : Integer;
        modules         : array of {
            module   : String;
            uploaded : Integer;
            approved : Integer;
            rejected : Integer;
        };
        table           : array of {
            module    : String;
            subModule : String;
            loadType  : String;
            template  : String;
            count     : Integer;
        };
    };

    // 🔥 NEW SANKY FUNCTION
    function getSankeyData() returns array of {
        period    : String;
        module    : String;
        value     : Integer;
        templates : array of {
            name  : String;
            value : Integer;
        };
    };
}




const cds = require('@sap/cds');

module.exports = cds.service.impl(async function () {

    const { ReportFileStorage, TemplateStorage } = cds.entities('com.scb.fileupload.master');

    // =========================
    // MODULE DROPDOWN
    // =========================
    this.on('getModules', async () => {

        const data = await cds.run(
            SELECT.distinct.from(TemplateStorage).columns('MODULE_NAME').orderBy('MODULE_NAME')
        );

        return data.map(d => ({
            module: d.MODULE_NAME
        }));
    });

    // =========================
    // DASHBOARD
    // =========================
    this.on('getDashboardData', async (req) => {

        let modules = req.data.module || [];

        if (typeof modules === "string") {
            modules = [modules];
        }

        let reportData = [];
        let templateData = [];

        if (modules.length > 0) {
            reportData = await cds.run(
                SELECT.from(ReportFileStorage).where({ MODULE_NAME: { in: modules } })
            );
            templateData = await cds.run(
                SELECT.from(TemplateStorage).where({ MODULE_NAME: { in: modules } })
            );
        } else {
            reportData = await cds.run(SELECT.from(ReportFileStorage));
            templateData = await cds.run(SELECT.from(TemplateStorage));
        }

        // KPI
        let uploaded = 0, approved = 0, rejected = 0;

        reportData.forEach(r => {
            if (r.STATUS === 'uploaded') uploaded++;
            if (r.STATUS === 'approved') approved++;
            if (r.STATUS === 'rejected') rejected++;
        });

        // CHART
        const moduleMap = {};

        reportData.forEach(r => {
            if (!moduleMap[r.MODULE_NAME]) {
                moduleMap[r.MODULE_NAME] = {
                    module: r.MODULE_NAME,
                    uploaded: 0,
                    approved: 0,
                    rejected: 0
                };
            }

            if (r.STATUS === 'uploaded') moduleMap[r.MODULE_NAME].uploaded++;
            if (r.STATUS === 'approved') moduleMap[r.MODULE_NAME].approved++;
            if (r.STATUS === 'rejected') moduleMap[r.MODULE_NAME].rejected++;
        });

        const modulesData = Object.values(moduleMap);

        // TABLE
        const tableMap = {};

        reportData.forEach(r => {
            const key = `${r.MODULE_NAME}_${r.SUB_MODULE_NAME}_${r.LOAD_TYPE}_${r.LOAD_TEMPLATE}`;

            if (!tableMap[key]) {
                tableMap[key] = {
                    module: r.MODULE_NAME,
                    subModule: r.SUB_MODULE_NAME,
                    loadType: r.LOAD_TYPE,
                    template: r.LOAD_TEMPLATE,
                    count: 0
                };
            }

            tableMap[key].count++;
        });

        const table = Object.values(tableMap);

        return {
            uploaded,
            approved,
            rejected,
            totalTemplates: templateData.length,
            modules: modulesData,
            table
        };
    });

    // =========================
    // 🔥 SANKY BACKEND
    // =========================
    this.on('getSankeyData', async () => {

        const data = await cds.run(SELECT.from(ReportFileStorage));

        const now = new Date();

        const startOfMonth = new Date(now.getFullYear(), now.getMonth(), 1);
        const startOfQuarter = new Date();
        startOfQuarter.setMonth(now.getMonth() - 3);

        const startOfYear = new Date();
        startOfYear.setFullYear(now.getFullYear() - 1);

        function filterByDate(startDate) {
            return data.filter(d => new Date(d.CREATEDAT) >= startDate);
        }

        function process(periodName, records) {

            const moduleCount = {};
            const templateCount = {};

            records.forEach(r => {

                const module = r.MODULE_NAME;
                const template = r.LOAD_TEMPLATE;

                moduleCount[module] = (moduleCount[module] || 0) + 1;

                if (!templateCount[module]) templateCount[module] = {};
                templateCount[module][template] = (templateCount[module][template] || 0) + 1;
            });

            const topModules = Object.entries(moduleCount)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 3);

            return topModules.map(([module, count]) => {

                const templates = Object.entries(templateCount[module] || {})
                    .sort((a, b) => b[1] - a[1])
                    .slice(0, 3)
                    .map(([name, value]) => ({ name, value }));

                return {
                    period: periodName,
                    module,
                    value: count,
                    templates
                };
            });
        }

        return [
            ...process("Monthly", filterByDate(startOfMonth)),
            ...process("Quarterly", filterByDate(startOfQuarter)),
            ...process("Yearly", filterByDate(startOfYear))
        ];
    });

});




onAfterRendering: function () {

    fetch("/odata/v4/mfu/getSankeyData()")
        .then(res => res.json())
        .then(data => {

            const result = data.value || [];

            const nodes = [];
            const links = [];

            nodes.push({ name: "Monthly" }, { name: "Quarterly" }, { name: "Yearly" });

            result.forEach(r => {

                nodes.push({ name: r.module });

                links.push({
                    source: r.period,
                    target: r.module,
                    value: r.value
                });

                r.templates.forEach(t => {
                    nodes.push({ name: t.name });

                    links.push({
                        source: r.module,
                        target: t.name,
                        value: t.value
                    });
                });
            });

            const chart = echarts.init(document.getElementById("sankeyChart"));

            chart.setOption({
                series: [{
                    type: "sankey",
                    data: nodes,
                    links: links,
                    emphasis: { focus: "adjacency" }
                }]
            });

        });
}
