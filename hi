(function () {

class AnalyticalTableWidget extends HTMLElement {

    connectedCallback() {

        this._containerId = "ui5_content_" + Math.floor(Math.random() * 100000);

        this.innerHTML = `<div id="${this._containerId}" style="width:100%;height:100%"></div>`;

        this._loadUI5();
    }

    async _loadUI5() {

        if (!window.sap) {

            const script = document.createElement("script");
            script.src = "https://sapui5.hana.ondemand.com/resources/sap-ui-core.js";

            script.id = "sap-ui-bootstrap";
            script.setAttribute("data-sap-ui-theme", "sap_fiori_3");
            script.setAttribute("data-sap-ui-libs", "sap.ui.table,sap.m");
            script.setAttribute("data-sap-ui-async", "true");

            document.head.appendChild(script);

            await new Promise(resolve => script.onload = resolve);
        }

        this._createTable();
    }

    _createTable() {

        const renderTable = () => {

            const oModel = new sap.ui.model.odata.v2.ODataModel(
                "https://services.odata.org/V2/Northwind/Northwind.svc/"
            );

            const oTable = new sap.ui.table.Table({
                title: "Products Table",
                visibleRowCount: 10,
                selectionMode: "MultiToggle"
            });

            oTable.setModel(oModel);
            oTable.bindRows("/Products");

            oTable.addColumn(new sap.ui.table.Column({
                label: new sap.m.Label({ text: "Product ID" }),
                template: new sap.m.Text({ text: "{ProductID}" })
            }));

            oTable.addColumn(new sap.ui.table.Column({
                label: new sap.m.Label({ text: "Product Name" }),
                template: new sap.m.Text({ text: "{ProductName}" })
            }));

            oTable.addColumn(new sap.ui.table.Column({
                label: new sap.m.Label({ text: "Unit Price" }),
                template: new sap.m.Text({ text: "{UnitPrice}" })
            }));

            oTable.addColumn(new sap.ui.table.Column({
                label: new sap.m.Label({ text: "Units In Stock" }),
                template: new sap.m.Text({ text: "{UnitsInStock}" })
            }));

            oTable.placeAt(this._containerId);

        };

        if (sap.ui.getCore().isInitialized()) {
            renderTable();
        } else {
            sap.ui.getCore().attachInit(renderTable);
        }

    }

}

customElements.define("analytical-table-widget", AnalyticalTableWidget);

})();



import "./AnalyticalTableWidget";

function App() {
  return (
    <div style={{height:"600px"}}>
      <analytical-table-widget />
    </div>
  );
}

export default App;
