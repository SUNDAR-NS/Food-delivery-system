                                            module: "NFRP",
                                            submodule: "Vendor",
                                            status: "Approved"
                                        }
                                    }
                                ]
                            },
                            {
                                name: "Pending",
                                children: [
                                    {
                                        name: "NFRP_GL_MAPPING",
                                        value: 5,
                                        meta: {
                                            user: "Priya Shah",
                                            created: "15-Feb-2026",
                                            approved: "-",
                                            module: "NFRP",
                                            submodule: "Finance",
                                            status: "Pending"
                                        }
                                    }
                                ]
                            },
                            {
                                name: "Rejected",
                                children: [
                                    {
                                        name: "NFRP_COST_CENTER",
                                        value: 3,
                                        meta: {
                                            user: "Neha Jain",
                                            created: "08-Feb-2026",
                                            approved: "-",
                                            module: "NFRP",
                                            submodule: "CO",
                                            status: "Rejected"
                                        }
                                    }
                                ]
                            }
                        ]
                    },

                    {
                        name: "SCBI",
                        children: [
                            {
                                name: "Approved",
                                children: [
                                    {
                                        name: "SCBI_LOAN_TEMPLATE_V2",
                                        value: 14,
                                        meta: {
                                            user: "David Lee",
                                            created: "01-Feb-2026",
                                            approved: "02-Feb-2026",
                                            module: "SCBI",
