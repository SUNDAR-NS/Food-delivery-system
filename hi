TRIGGER "AUTO_ID_TRIGGER"
BEFORE INSERT ON "T1CLIENTMI_PHY.db::3TL_CLNTMI_ESG_DICX_LOCATION"
REFERENCING NEW ROW AS NEW
FOR EACH ROW
BEGIN
    SELECT 
        CASE 
            WHEN :NEW."ID" IS NULL 
            THEN SUBSTRING(REPLACE(TO_NVARCHAR(SYSUUID),'-',''),1,18)
            ELSE :NEW."ID"
        END
    INTO :NEW."ID"
    FROM DUMMY;
END;
