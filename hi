<mvc:View controllerName="mfuanalytics.controller.mfureport"  
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"  
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"  
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">  

<Page title="MFU Dashboard" class="sapBlueHeader">  

<VBox class="mainContainer">  

<!-- FILTER -->
<Panel class="moduleFilterBox">
<HBox class="filterRow" alignItems="Center" justifyContent="SpaceBetween">

<VBox class="filterItem">
<Text text="Module" class="filterLabel"/>
<MultiComboBox id="moduleFilter" width="210px"
selectionFinish="onFilterChange"
items="{/allModules}" showClearIcon="true">
<core:Item key="{module}" text="{module}" />
</MultiComboBox>
</VBox>

<VBox class="filterItem">
<Text text="Status" class="filterLabel"/>
<MultiComboBox id="statusFilter" width="180px"
selectionFinish="onFilterChange"
items="{/statusList}" showClearIcon="true">
<core:Item key="{key}" text="{text}" />
</MultiComboBox>
</VBox>

<VBox class="filterItem">
<Text text="User" class="filterLabel"/>
<MultiComboBox id="userFilter" width="180px"
selectionFinish="onFilterChange"
items="{/userList}" showClearIcon="true">
<core:Item key="{key}" text="{text}" />
</MultiComboBox>
</VBox>

<VBox class="filterItem">
<Text text="Created Date" class="filterLabel"/>
<MultiComboBox id="dateFilter" width="200px"
selectionFinish="onFilterChange"
items="{/dateList}" showClearIcon="true">
<core:Item key="{key}" text="{text}" />
</MultiComboBox>
</VBox>

</HBox>
</Panel>

<!-- KPI + CHART -->
<HBox class="topContainer">  

<VBox width="35%">  

<HBox class="kpiRow">  
<GenericTile header="Total Uploaded" class="tile uploadedTile">  
<TileContent>
<NumericContent value="{/totalUploaded}" icon="sap-icon://upload"/>
</TileContent>  
</GenericTile>  

<GenericTile header="Total Approved" class="tile approvedTile">
<TileContent>
<NumericContent value="{/totalApproved}" icon="sap-icon://accept"/>
</TileContent>  
</GenericTile>  
</HBox>  

<HBox class="kpiRow">  
<GenericTile header="Total Rejected" class="tile rejectedTile">  
<TileContent>
<NumericContent value="{/totalRejected}" icon="sap-icon://decline"/>
</TileContent>  
</GenericTile>  

<GenericTile header="Total Templates" class="tile templateTile">  
<TileContent>
<NumericContent value="{/totalTemplates}" icon="sap-icon://document-text"/>
</TileContent>  
</GenericTile>  
</HBox>  

</VBox>  

<!-- CHART PANEL -->
<Panel width="700px">

<Toolbar class="panelTitle">
<Title text="MFU Templates by Modules"/>
<ToolbarSpacer/>
<Button text="Treemap" icon="sap-icon://switch-views" press="onToggleChart"/>
</Toolbar>

<VBox id="vizContainer" visible="true">
<viz:VizFrame id="idVizFrame" vizType="stacked_column" height="320px" width="100%"
vizProperties='{
"title": { "visible": false },
"legend": { "visible": true, "position":"right" },
"plotArea": {
"dataLabel": { "visible": false, "showTotal": true },
"dataLabelTotal": { "visible": true },
"drawingEffect": "glossy",
"colorPalette":["#0a6ed1","#107e3e","#e9730c"],
"animation":{"dataLoading":true}
},
"valueAxis":{"title":{"visible":true}},
"categoryAxis":{"title":{"visible":true}}
}'>

<viz:dataset>
<viz.data:FlattenedDataset data="{/modules}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}" />
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Uploaded" value="{uploaded}" />
<viz.data:MeasureDefinition name="Approved" value="{approved}" />
<viz.data:MeasureDefinition name="Rejected" value="{rejected}" />
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure"
values="Uploaded,Approved,Rejected"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension"
values="Module"/>
</viz:feeds>
</viz:VizFrame>
</VBox>

<VBox id="treemapContainer" visible="false">
<core:HTML content="<div id='treemapChart' style='width:100%;height:320px'></div>" />
</VBox>

</Panel>  

</HBox>  

<!-- EXTRA CHARTS -->
<HBox class="chartRow">

<VBox class="chartBox">
<Text text="Templates by Count" class="panelTitle"/>
<viz:VizFrame vizType="pie" height="200px" width="100%">
<viz:dataset>
<viz.data:FlattenedDataset data="{/pieModules}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Approved" value="{approved}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>
<viz:feeds>
<viz.feeds:FeedItem uid="size" type="Measure" values="Approved"/>
<viz.feeds:FeedItem uid="color" type="Dimension" values="Module"/>
</viz:feeds>
</viz:VizFrame>
</VBox>

<VBox class="chartBox">
<Text text="Top MFU Usage" class="panelTitle"/>
<core:HTML content="<div id='sankeyChart' style='width:800px;height:200px'></div>" />
</VBox>

</HBox>

<!-- TABLE -->
<Panel class="sapUiMediumMarginTop">

<headerToolbar>
<Toolbar>
<Title text="MFU Details" icon="sap-icon://table-chart"/>
<ToolbarSpacer/>
<Text text="Total Records: {/tableData/length}"/>
</Toolbar>
</headerToolbar>

<ScrollContainer height="300px" vertical="true">

<Table sticky="ColumnHeaders" items="{/tableData}" width="100%" mode="SingleSelectMaster">

<columns>
<Column><Text text="Module"/></Column>
<Column><Text text="Sub Module"/></Column>
<Column><Text text="Load Type"/></Column>
<Column><Text text="Template"/></Column>
<Column><Text text="Count"/></Column>
</columns>

<items>
<ColumnListItem type="Active" press="onRowPress">
<cells>
<Text text="{module}"/>
<Text text="{subModule}"/>
<Text text="{loadType}"/>
<Text text="{template}"/>
<Text text="{count}"/>
</cells>
</ColumnListItem>
</items>

</Table>
</ScrollContainer>

</Panel>

</VBox>  
</Page>  

<!-- DIALOG -->
<Dialog id="templateDialog" title="Template Details" draggable="true" resizable="true">
<content>
<ObjectHeader
title="{detail>/template}"
number="{detail>/status}"
intro="{detail>/module}">
<attributes>
<ObjectAttribute title="User" text="{detail>/user}"/>
<ObjectAttribute title="SubModule" text="{detail>/submodule}"/>
</attributes>
</ObjectHeader>

<Table items="{detail>/rows}">
<columns>
<Column><Text text="Property"/></Column>
<Column><Text text="Value"/></Column>
</columns>
<items>
<ColumnListItem>
<cells>
<Text text="{detail>key}"/>
<Text text="{detail>value}"/>
</cells>
</ColumnListItem>
</items>
</Table>
</content>

<endButton>
<Button text="Close" press="onCloseDialog"/>
</endButton>
</Dialog>

</mvc:View>
