        loadSankey: function () {

            fetch("/odata/v4/mfu/getSankeyData()")
                .then(res => res.json())
                .then(data => {

                    const result = data.value || [];
 
                    if (result.length === 0) {
                        console.log("❌ No Sankey Data");
                        return;
                    }
 
                    const nodeSet = new Set();
                    const links = [];
 
                    result.forEach(r => {
 
                        nodeSet.add(r.period);
                        nodeSet.add(r.module);
 
                        links.push({
                            source: r.period,
                            target: r.module,
                            value: r.value
                        });
 
                        (r.templates || []).forEach(t => {
 
                            nodeSet.add(t.name);
 
                            links.push({
                                source: r.module,
                                target: t.name,
                                value: t.value
                            });
 
                        });
                    });
 
                    const nodes = Array.from(nodeSet).map(n => ({ name: n }));
 
                    var chartDom = document.getElementById("sankeyChart");
 
                    if (!chartDom) {
                        return;
                    }
 
                    var chart = echarts.init(chartDom);
 
                    chart.setOption({
                        tooltip: {
                            trigger: "item"
                        },
                        series: [
                            {
                                type: "sankey",
                                nodeAlign: "left",
                                data: nodes,
                                links: links,
                                lineStyle: {
                                    curveness: 0.5
                                },
                                emphasis: {
                                    focus: "adjacency"
                                }
                            }
                        ]
                    });
 
                })
                .catch(err => {
                    console.error("SANKEY ERROR:", err);
                });
        },

        onFilterChange: function (oEvent) {
