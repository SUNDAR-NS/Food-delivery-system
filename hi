{
  "name": "MFUAnalytics",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,

  "dependencies": {
    "@sap/cds": "^8.9.4",
    "express": "^4",

    "@sap/cds-hana": "^2.1.0",
    "@sap/hana-client": "^2.25.29",
    "@sap/xssec": "4.9.0",

    "body-parser": "2.2.0"
  },

  "devDependencies": {
    "@cap-js/sqlite": "^1",
    "@cap-js/cds-types": "^0.8.0",
    "cds-plugin-ui5": "^0.13.0"
  },

  "scripts": {
    "start": "cds-serve",
    "build": "cds build",
    "deploy": "cds deploy --to hana",

    "watch-mfuanalytics": "cds watch --open mfuanalytics/index.html?sap-ui-xx-viewCache=false --livereload false"
  },

  "workspaces": [
    "app/*"
  ],

  "cds": {
    "requires": {

      "auth": {
        "[development]": {
          "kind": "basic",
          "users": {
            "admin": {
              "roles": ["Admin"],
              "attr": {
                "givenName": "Admin",
                "familyName": "User",
                "email": "admin@test.com"
              }
            }
          }
        },
        "[production]": {
          "kind": "xsuaa"
        }
      },

      "db": {
        "kind": "hana"
      },

      "server": {
        "body_parser": {
          "limit": "50mb"
        }
      },

      "sql": {
        "native_hana_associations": false
      }
    }
  }
}
