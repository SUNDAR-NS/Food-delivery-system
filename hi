<viz:VizFrame
    id="_IDGenVizFrame1"
    vizType="donut"
    height="230px"
    width="100%"
    vizProperties='{
        "title": { "visible": false },

        "legend": {
            "visible": true,
            "position": "right"
        },

        "plotArea": {
            "innerRadius": "60%",
            "dataLabel": {
                "visible": true,
                "type": "percentage"
            }
        },

        "interaction": {
            "selectability": {
                "mode": "SINGLE"
            }
        }
    }'
>

    <viz:dataset>
        <viz.data:FlattenedDataset data="{/pieModules}">

            <!-- 🔥 USER -->
            <viz.data:dimensions>
                <viz.data:DimensionDefinition
                    name="User"
                    value="{user}" />
            </viz.data:dimensions>

            <!-- 🔥 COUNT -->
            <viz.data:measures>
                <viz.data:MeasureDefinition
                    name="Templates"
                    value="{count}" />
            </viz.data:measures>

        </viz.data:FlattenedDataset>
    </viz:dataset>

    <viz:feeds>
        <!-- SIZE -->
        <viz.feeds:FeedItem
            uid="size"
            type="Measure"
            values="Templates"/>

        <!-- COLOR -->
        <viz.feeds:FeedItem
            uid="color"
            type="Dimension"
            values="User"/>
    </viz:feeds>

</viz:VizFrame>
