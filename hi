onTableFilter: function () {  
  
    var oTable = this.byId("_IDGenTable");  
    var oBinding = oTable.getBinding("items");  
  
    var aFilters = [];  
  
    oTable.getColumns().forEach(col => {  
  
        var header = col.getHeader();  
  
        if (header instanceof sap.m.VBox) {  
  
            var input = header.getItems()[1];  
            var value = input.getValue();  
  
            if (value) {  
  
                var field = input.getPlaceholder();  
  
                aFilters.push(new sap.ui.model.Filter(  
                    field,  
                    sap.ui.model.FilterOperator.Contains,  
                    value  
                ));  
            }  
        }  
    });  
  
    oBinding.filter(aFilters);  
},  
  
onHeaderClick: function (oEvent) {  
  
    var oVBox = oEvent.getSource().getParent();  
    var oInput = oVBox.getItems()[1];  
  
    // toggle input  
    oInput.setVisible(!oInput.getVisible());  
},  
  
  
