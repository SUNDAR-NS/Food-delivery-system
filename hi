{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/rest/(.*)$",
      "target": "/$1",
      "destination": "reactexperienceapp-destination-service",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^(.*)$",
      "localDir": "../reactui/build",
      "authenticationType": "xsuaa"
    }
  ]
}
