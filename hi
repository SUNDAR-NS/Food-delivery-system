<mvc:View controllerName="mfuanalytics.controller.mfureport"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

<Page title="MFU Dashboard">

<VBox class="mainContainer">

<Title text="MFU Analytics Dashboard" level="H2"/>

<!-- KPI -->
<layout:Grid defaultSpan="L3 M6 S12" class="sapUiMediumMarginTop">

<f:Card><f:content><VBox class="sapUiSmallMargin">
<NumericContent value="71" valueColor="Good"/>
<Text text="Total Uploaded"/>
</VBox></f:content></f:Card>

<f:Card><f:content><VBox class="sapUiSmallMargin">
<NumericContent value="60" valueColor="Good"/>
<Text text="Approved"/>
</VBox></f:content></f:Card>

<f:Card><f:content><VBox class="sapUiSmallMargin">
<NumericContent value="115"/>
<Text text="Templates"/>
</VBox></f:content></f:Card>

<f:Card><f:content><VBox class="sapUiSmallMargin">
<NumericContent value="5" valueColor="Error"/>
<Text text="Rejected"/>
</VBox></f:content></f:Card>

</layout:Grid>

<!-- MAIN CHART -->
<f:Card class="sapUiMediumMarginTop">
<f:content>
<VBox class="sapUiSmallMargin">
<Title text="MFU Templates by Module" level="H5"/>

<viz:VizFrame vizType="column" height="350px">

<viz:dataset>
<viz.data:FlattenedDataset data="{/modules}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Approved" value="{approved}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Approved"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Module"/>
</viz:feeds>

</viz:VizFrame>

</VBox>
</f:content>
</f:Card>

<!-- BOTTOM -->
<layout:Grid defaultSpan="L3 M6 S12" class="sapUiMediumMarginTop">

<!-- PIE -->
<f:Card><f:content><VBox class="sapUiSmallMargin">
<Title text="Distribution"/>

<viz:VizFrame vizType="donut" height="220px">

<viz:dataset>
<viz.data:FlattenedDataset data="{/modules}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{approved}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="size" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="color" type="Dimension" values="Module"/>
</viz:feeds>

</viz:VizFrame>

</VBox></f:content></f:Card>

<!-- MONTHLY -->
<f:Card><f:content><VBox class="sapUiSmallMargin">
<Title text="Monthly Trend"/>

<viz:VizFrame vizType="column" height="220px">

<viz:dataset>
<viz.data:FlattenedDataset data="{/monthly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Month" value="{month}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month"/>
</viz:feeds>

</viz:VizFrame>

</VBox></f:content></f:Card>

<!-- QUARTERLY -->
<f:Card><f:content><VBox class="sapUiSmallMargin">
<Title text="Quarterly"/>

<viz:VizFrame vizType="column" height="220px">

<viz:dataset>
<viz.data:FlattenedDataset data="{/quarterly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Quarter" value="{quarter}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Quarter"/>
</viz:feeds>

</viz:VizFrame>

</VBox></f:content></f:Card>

<!-- YEARLY -->
<f:Card><f:content><VBox class="sapUiSmallMargin">
<Title text="Yearly"/>

<viz:VizFrame vizType="column" height="220px">

<viz:dataset>
<viz.data:FlattenedDataset data="{/yearly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Year" value="{year}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Year"/>
</viz:feeds>

</viz:VizFrame>

</VBox></f:content></f:Card>

</layout:Grid>

</VBox>
</Page>
</mvc:View>




.sapMPage {
    background-color: #f5f7fa;
}

.mainContainer {
    padding: 1.5rem;
    max-width: 1400px;
    margin: auto;
}

/* GRID */
.sapUiLayoutGrid {
    gap: 1rem !important;
}

/* CARD */
.sapFCard {
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    background: white;
}

/* CARD CONTENT */
.sapFCard .sapUiSmallMargin {
    padding: 10px;
}

/* TITLE */
.sapMTitle {
    font-weight: 600;
}

/* CHART */
.sapVizFrame {
    width: 100% !important;
}

/* FIX HEIGHT */
#idMainChart {
    min-height: 350px;
}

#idPie,
#idMonthly,
#idQuarterly,
#idYearly {
    min-height: 220px;
}
