    xmlns:viz.data="sap.viz.ui5.data"  
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">  

    <Page id="_IDGenPage" title="MFU Dashboard" class="sapHeader">  
        <VBox id="_IDGenVBox" class="mainContainer">  
            <Panel id="_IDGenPanel2"  class="moduleFilterBox">
                <VBox id="_IDGenVBox6" class="filterContainer">
                    <HBox id="_IDGenHBox" alignItems="Center" class="filterRow">
                        <Text id="_IDGenText" text="Module" class="filterLable"/>
                        <MultiComboBox id="_IDGenMultiComboBox1"
                            width="200px"
                            selectionFinish="onFilterChange"
                            items="{/allModules}"
                            showClearIcon="true">
                            <core:Item id="_IDGenItem" key="{module}" text="{module}" />
                        </MultiComboBox>
                    </HBox>
                </VBox>
            </Panel>

            <HBox id="_IDGenHBox3" class="topContainer">  
                <VBox id="_IDGenVBox1" width="35%">  
                    <HBox id="_IDGenHBox4" class="kpiRow">  
                        <GenericTile id="_IDGenGenericTile" header="Total Uploaded" class="tile tileUpload">  
                            <TileContent id="_IDGenTileContent">
                                <NumericContent id="_IDGenNumericContent" value="{/totalUploaded}"
                                icon="sap-icon://upload"
                                valueColor="None"/>
                            </TileContent>  
                        </GenericTile>  
                        <GenericTile id="_IDGenGenericTile1" header="Total Approved" class="tile tileApproved">  
                            <TileContent id="_IDGenTileContent1">
                                <NumericContent id="_IDGenNumericContent1" value="{/totalApproved}"
                                icon="sap-icon://accept"
                                valueColor="Good"/>
                            </TileContent>  
                        </GenericTile>  
                    </HBox>  
                    <HBox id="_IDGenHBox5" class="kpiRow">  
                        <GenericTile id="_IDGenGenericTile2" header="Total Pending" class="tile tilePending">  
                            <TileContent id="_IDGenTileContent2">
                                <NumericContent id="_IDGenNumericContent2" value="{/totalPending}" 
                                icon="sap-icon://pending"
                                valueColor="Critical"/>
                            </TileContent>  
                        </GenericTile>  
                        <GenericTile id="_IDGenGenericTile3" header="Total Templates" class="tile tileTemplate">  
                            <TileContent id="_IDGenTileContent3">
                                <NumericContent id="_IDGenNumericContent3" value="{/totalTemplates}"
                                icon="sap-icon://document-text"
                                valueColor="Neutral"/>
                            </TileContent>  
                        </GenericTile>  
                    </HBox>  
                </VBox>  
                <Panel id="_IDGenPanel" width="800px">
                    <Toolbar class="panelTitle">
                            <Title text="MFU Templates by Modules" />
                        <ToolbarSpacer/>
                            <Button 
                                text="Treemap"
                                icon="sap-icon://switch-views"
                                press="onToggleChart"/>
                    </Toolbar>
                    <VBox id="vizContainer" visible="true">
                        <viz:VizFrame id="_IDGenVizFrame" vizType="stacked_column" height="320px" width="100%"
                            vizProperties='{
                                "title": { "visible": false },
                                "legend": {
                                "visible": true,
                                "position":"right"
                                },
                                "plotArea": {
                                    "dataLabel": { 
                                        "visible": false,
                                        "showTotal": true
                                    },
                                    "dataLabelTotal": {
                                        "visible": true
                                    },
                                    
                                    "drawingEffect": "glossy",
                                    "colorPalette":[
                                        "#0a6ed1",
                                        "#107e3e",
                                        "#e9730c"
                                    ],
                                    "animation":{
                                    "dataLoading":true
                                    }
                                },
                                "valueAxis":{
                                "title":{"visible":true}
                                },
                                "categoryAxis":{
                                "title":{"visible":true}
                                },
                                "interaction": {
                                    "selectability": {
                                        "mode": "MULTIPLE"
                                    }
                                }
                            }'
                            >
                            <viz:dataset>
                                <viz.data:FlattenedDataset id="_IDGenFlattenedDataset" data="{/modules}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition id="_IDGenDimensionDefinition" name="Module" value="{module}" />
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition id="_IDGenMeasureDefinition" name="Uploaded" value="{uploaded}" />
                                        <viz.data:MeasureDefinition id="_IDGenMeasureDefinition1" name="Approved" value="{approved}" />
                                        <viz.data:MeasureDefinition id="_IDGenMeasureDefinition2" name="Pending" value="{pending}" />
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem id="_IDGenFeedItem" uid="valueAxis" type="Measure"
                                    values="Uploaded,Approved,Pending"/>
                                <viz.feeds:FeedItem id="_IDGenFeedItem1" uid="categoryAxis" type="Dimension"
                                    values="Module"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>
                    <VBox id="treemapContainer" visible="false">
                        <core:HTML
                            content="&lt;div id='treemapChart' style='width:100%;height:320px'&gt;&lt;/div&gt;" />
                    </VBox>
                </Panel>  
            </HBox> 

            <HBox id="_IDGenHBox6" class="chartRow">
                <VBox id="_IDGenVBox2" class="chartBox">
                    <Text id="_IDGenText1" text="Templates by Count" class="panelTitle"/>
                    <viz:VizFrame id="_IDGenVizFrame1" vizType="pie" height="200px" width="100%"
                        vizProperties='{"title":{"visible":false}}'>
                        <viz:dataset>
                            <viz.data:FlattenedDataset id="_IDGenFlattenedDataset1" data="{/pieModules}">
                                <viz.data:dimensions>
                                    <viz.data:DimensionDefinition id="_IDGenDimensionDefinition1" name="Module" value="{module}"/>
                                </viz.data:dimensions>
                                <viz.data:measures>
                                    <viz.data:MeasureDefinition id="_IDGenMeasureDefinition3" name="Approved" value="{approved}"/>
                                </viz.data:measures>
                            </viz.data:FlattenedDataset>
                        </viz:dataset>
                        <viz:feeds>
                            <viz.feeds:FeedItem id="_IDGenFeedItem2" uid="size" type="Measure" values="Approved"/>
                            <viz.feeds:FeedItem id="_IDGenFeedItem3" uid="color" type="Dimension" values="Module"/>
                        </viz:feeds>
                    </viz:VizFrame>
                </VBox>
                <VBox id="_IDGenVBox7" class="chartBox">
                    <Text id="_IDGenText99" text="Top MFU Usage" class="panelTitle"/>
                    <core:HTML
                        id="sankeyHtml"
                        content="&lt;div id='sankeyChart' style='width:800px;height:200px'&gt;&lt;/div&gt;" />
                </VBox>
            </HBox>
            
            <Panel id="_IDGenPanel1" class="sapUiMediumMarginTop">
            <Toolbar class="panelTitle">
                            <Title text="MFU Details" />
                    </Toolbar>
                <Table id="_IDGenTable" items="{/tableData}">
                    <columns>
                        <Column id="_IDGenColumn1"><Text id="_IDGenText5" text="Module"/></Column>
                        <Column id="_IDGenColumn2"><Text id="_IDGenText6" text="Sub Module"/></Column>
                        <Column id="_IDGenColumn3"><Text id="_IDGenText7" text="Load Type"/></Column>
                        <Column id="_IDGenColumn4"><Text id="_IDGenText8" text="Template"/></Column>
                        <Column id="_IDGenColumn5"><Text id="_IDGenText9" text="Count"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem id="_IDGenColumnListItem">
                            <cells>
                                <Text id="_IDGenText10" text="{module}"/>
                                <Text id="_IDGenText11" text="{subModule}"/>
                                <Text id="_IDGenText12" text="{loadType}"/>
                                <Text id="_IDGenText13" text="{template}"/>
                                <Text id="_IDGenText14" text="{count}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </Panel>
        </VBox> 
        <!-- <Button text="new" press="onNewPress"></Button>  -->
    </Page>  

    <Dialog
        id="templateDialog"
        contentWidth="600px"
        contentHeight="auto"
        draggable="true"
        resizable="true"
        title="Template Details">
        <content>
            <ObjectHeader
                title="{detail>/template}"
                number="{detail>/status}"
                numberState="{detail>/statusState}"
                intro="{detail>/module}"
                icon="sap-icon://document-text">
                <attributes>
                    <ObjectAttribute title="User" text="{detail>/user}"/>
                    <ObjectAttribute title="SubModule" text="{detail>/submodule}"/>
                </attributes>
            </ObjectHeader>
            <Table
                inset="false"
                class="sapUiSmallMarginTop"
                items="{detail>/rows}">
                <columns>
                    <Column>
                        <Text text="Property"/>
                    </Column>
                    <Column>
                        <Text text="Value"/>
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{detail>key}"/>
                            <Text text="{detail>value}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <endButton>
            <Button text="Close" type="Emphasized" press=".onCloseDialog"/>
        </endButton>
    </Dialog>
</mvc:View>

