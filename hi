<columns>

    <!-- Module -->
    <Column>
        <VBox class="filterHeader">
            <Link text="Module" press="onHeaderClick"/>
            <Input visible="false"
                   liveChange="onTableFilter"
                   placeholder="Search Module">
                <customData>
                    <core:CustomData key="field" value="module"/>
                </customData>
            </Input>
        </VBox>
    </Column>

    <!-- Sub Module -->
    <Column>
        <VBox class="filterHeader">
            <Link text="Sub Module" press="onHeaderClick"/>
            <Input visible="false"
                   liveChange="onTableFilter"
                   placeholder="Search Sub Module">
                <customData>
                    <core:CustomData key="field" value="subModule"/>
                </customData>
            </Input>
        </VBox>
    </Column>

    <!-- Load Type -->
    <Column>
        <VBox class="filterHeader">
            <Link text="Load Type" press="onHeaderClick"/>
            <Input visible="false"
                   liveChange="onTableFilter"
                   placeholder="Search Load Type">
                <customData>
                    <core:CustomData key="field" value="loadType"/>
                </customData>
            </Input>
        </VBox>
    </Column>

    <!-- Template -->
    <Column>
        <VBox class="filterHeader">
            <Link text="Template" press="onHeaderClick"/>
            <Input visible="false"
                   liveChange="onTableFilter"
                   placeholder="Search Template">
                <customData>
                    <core:CustomData key="field" value="template"/>
                </customData>
            </Input>
        </VBox>
    </Column>

    <!-- Count -->
    <Column>
        <Text text="Load Count"/>
    </Column>

</columns>
