TRIGGER "TRI_SYNC_STAGE_TO_MAIN"
AFTER INSERT
ON "T1CLIENTMI_PHY.db::MFU_DICX_LOCATION_STAGE"

BEGIN

    DELETE FROM "T1CLIENTMI_PHY.db::3TL_CLNTMI_ESG_DICX_LOCATION";

    INSERT INTO "T1CLIENTMI_PHY.db::3TL_CLNTMI_ESG_DICX_LOCATION"
    (
        "ID",
        "NAME",
        "LOCATION_HIERARCHY",
        "LOCATION_CTRY_DAC_KEY",
        "LATITUDE",
        "LONGITUDE",
        "EXPIRY_DATE"
    )
    SELECT
        SUBSTRING(TO_NVARCHAR(SYSUUID),1,18),
        "NAME",
        "LOCATION_HIERARCHY",
        "LOCATION_CTRY_DAC_KEY",
        "LATITUDE",
        "LONGITUDE",
        "EXPIRY_DATE"
    FROM "T1CLIENTMI_PHY.db::MFU_DICX_LOCATION_STAGE";

END;
