<Page class="sapBlueHeader">

    <customHeader>
        <Bar class="customHeaderBar">

            <contentMiddle>
                <HBox alignItems="Center" gap="10px" justifyContent="Center" width="100%">
                    
                    <Icon src="sap-icon://business-objects-experience" size="1.6rem"/>
                    
                    <VBox>
                        <Title text="MFU Dashboard"/>
                        <Text text="Monitoring & Analytics"/>
                    </VBox>

                </HBox>
            </contentMiddle>

        </Bar>
    </customHeader>




/* ========================= */
/* 🔥 CLEAN PROFESSIONAL HEADER */
/* ========================= */

.customHeaderBar {
    background: linear-gradient(90deg, #0a6ed1, #0854a0);
    height: 70px;
    display: flex;
    align-items: center;
}

/* Title */
.customHeaderBar .sapMTitle {
    color: white !important;
    font-weight: bold;
    font-size: 18px;
    text-align: center;
}

/* Subtitle */
.customHeaderBar .sapMText {
    color: #dbe8ff !important;
    font-size: 12px;
    text-align: center;
}

/* Icon */
.customHeaderBar .sapUiIcon {
    color: white !important;
}
