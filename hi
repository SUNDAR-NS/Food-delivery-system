    <Panel id="_IDGenPanel" width="65%" headerText="MFU Templates by Modules">

   <viz:VizFrame
    id="idVizFrame"
    vizType="stacked_column"
    width="100%"
    height="320px"
    vizProperties='{
  "plotArea": {
    "dataLabel": {
      "visible": true
    },
    "dataPointStyle": {
      "rules": [
        {
          "dataContext": { "measureNames": "Approved" },
          "properties": { "color": "#0070F2" }
        },
        {
          "dataContext": { "measureNames": "Rejected" },
          "properties": { "color": "#E9730C" }
        },
        {
          "dataContext": { "measureNames": "Pending" },
          "properties": { "color": "#107E3E" }
        }
      ]
    }
  }
}'>

    <viz:dataset>
        <viz.data:FlattenedDataset id="_IDGenFlattenedDataset" data="{/modules}">

            <viz.data:dimensions>
                <viz.data:DimensionDefinition id="_IDGenDimensionDefinition"
                    name="Module"
                    value="{module}" />
            </viz.data:dimensions>

            <viz.data:measures>
                <viz.data:MeasureDefinition id="_IDGenMeasureDefinition"
                    name="Approved"
                    value="{approved}" />

                <viz.data:MeasureDefinition id="_IDGenMeasureDefinition5"
                    name="Rejected"
                    value="{rejected}" />

                <viz.data:MeasureDefinition id="_IDGenMeasureDefinition6"
                    name="Pending"
                    value="{pending}" />
            </viz.data:measures>

        </viz.data:FlattenedDataset>
    </viz:dataset>

    <viz:feeds>

        <viz.feeds:FeedItem id="_IDGenFeedItem1"
            uid="valueAxis"
            type="Measure"
            values="Approved,Rejected,Pending"/>

        <viz.feeds:FeedItem id="_IDGenFeedItem10"
            uid="categoryAxis"
            type="Dimension"
            values="Module"/>

    </viz:feeds>

</viz:VizFrame>
    </Panel>






