/* 🔥 Header container */
.filterHeader {
    padding: 2px 0;
    gap: 4px;
}

/* 🔥 Make link look like normal header */
.sapMLnk {
    color: #32363a !important;
    text-decoration: none !important;
    font-weight: 600;
    font-size: 0.85rem;
}

/* 🔥 Hover effect like SAP */
.sapMLnk:hover {
    color: #0a6ed1 !important;
}

/* 🔥 Input styling */
.sapMInputBase {
    height: 1.8rem;
    font-size: 0.75rem;
}

/* 🔥 Smooth appearance */
.sapMInputBase {
    transition: all 0.2s ease-in-out;
}

/* 🔥 Focus effect */
.sapMInputBase:focus-within {
    border-color: #0a6ed1;
    box-shadow: 0 0 0 1px #0a6ed1;
}

/* 🔥 Column alignment fix */
.sapMListTblHeaderCell {
    vertical-align: top !important;
}

/* 🔥 Reduce header height */
.sapMColumnHeader {
    padding-top: 6px !important;
    padding-bottom: 6px !important;
}

/* 🔥 Input spacing */
.filterHeader .sapMInputBase {
    margin-top: 2px;
}

/* 🔥 Optional: subtle animation when showing input */
.sapMInputBase {
    opacity: 1;
}
