{
  "trigger": {
    "name": "AUTO_ID_TRIGGER",
    "table": "T1CLIENTMI_PHY.db::3TL_CLNTMI_ESG_DICX_LOCATION",
    "before": true,
    "insert": true,
    "forEachRow": true,
    "statement": "BEGIN IF :NEW.ID IS NULL THEN :NEW.ID := SUBSTRING(REPLACE(TO_NVARCHAR(SYSUUID),'-',''),1,18); END IF; END"
  }
}


VIEW "T1CLIENTMI_PHY.db::MFU_VIEW" AS
SELECT 
  "MFU_ID" AS "ID"
FROM "T1CLIENTMI_PHY.db::3TL_CLNTMI_ESG_DICX_LOCATION";
