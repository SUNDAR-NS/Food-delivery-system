                        ]
                    }
                    ]
                }]
            };
            treemapChart.setOption(option);

            var that = this;
            treemapChart.on("click", function (params) {
                if (params.data && params.data.meta) {
                    var meta = params.data.meta;
                    var statusState = "None";
                    if (meta.status === "Approved") statusState = "Success";
                    if (meta.status === "Pending") statusState = "Warning";
                    if (meta.status === "Rejected") statusState = "Error";
                    var oModel = new sap.ui.model.json.JSONModel({
                        template: params.data.name,
                        module: meta.module,
                        submodule: meta.submodule,
                        user: meta.user,
                        status: meta.status,
                        statusState: statusState,
                        rows: [
                            { key: "Created At", value: meta.created },
                            { key: "Approved At", value: meta.approved },
                            // { key: "Module", value: meta.module },
                            // { key: "SubModule", value: meta.submodule },
                            // { key: "User", value: meta.user }
                        ]
                    });
                    that.getView().setModel(oModel, "detail");
                    that.byId("templateDialog").open();
                }
            });
        },

        onCloseDialog: function () {
            this.byId("templateDialog").close();
        },

