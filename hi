loadPieChart: function () {

    fetch("/odata/v4/mfu/getPieData()")
        .then(res => res.json())
        .then(data => {

            console.log("PIE DATA:", data);

            this.getView().getModel().setProperty("/pieModules", data.value || []);

        })
        .catch(err => {
            console.error("PIE ERROR:", err);
        });
}
