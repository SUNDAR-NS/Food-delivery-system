using com.scb.fileupload.master as db from '../db/schema';

service MFUService {

    action getDashboardData(module: array of String) returns {
        uploaded        : Integer;
        approved        : Integer;
        rejected        : Integer;
        totalTemplates  : Integer;
        modules         : many {
            module   : String;
            uploaded : Integer;
            approved : Integer; 
            rejected : Integer;
        };
        table           : many {
            module    : String;
            subModule : String;
            loadType  : String;
            template  : String;
            count     : Integer;
        };
    };

    function getModules() returns many {
        module : String;
    };

    // 🔥 SANKEY
    function getSankeyData() returns many {
        period    : String;
        module    : String;
        value     : Integer;
        templates : many {
            name  : String;
            value : Integer;
        };
    };

    // 🔥 PIE (FIXED)
    function getPieData() returns many {
        user  : String;
        count : Integer;
    };
}
