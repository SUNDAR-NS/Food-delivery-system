<mvc:View controllerName="mfuanalytics.controller.mfureport"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls">

<Page title="MFU Dashboard">

<VBox class="mainContainer">

<!-- TOP -->
<HBox class="topContainer">

<VBox class="kpiSection">

<VBox class="kpiGrid">

<GenericTile header="MFU Onboarded" class="kpiCard">
<TileContent><NumericContent value="133"/></TileContent>
</GenericTile>

<GenericTile header="Total Approved" class="kpiCard">
<TileContent><NumericContent value="61"/></TileContent>
</GenericTile>

<GenericTile header="Total Uploaded" class="kpiCard">
<TileContent><NumericContent value="72"/></TileContent>
</GenericTile>

<GenericTile header="Rejected" class="kpiCard">
<TileContent><NumericContent value="0"/></TileContent>
</GenericTile>

</VBox>
</VBox>

<VBox class="chartSection">
<Panel headerText="MFU Templates by Modules">
<viz:VizFrame id="mainChart" vizType="column" height="300px"/>
</Panel>
</VBox>

</HBox>

<!-- BOTTOM -->
<HBox class="bottomGrid">

<Panel headerText="Templates by Count">
<viz:VizFrame id="pieChart" vizType="pie"/>
</Panel>

<Panel headerText="Monthly">
<viz:VizFrame id="monthChart" vizType="column"/>
</Panel>

<Panel headerText="Quarterly">
<viz:VizFrame id="quarterChart" vizType="column"/>
</Panel>

<Panel headerText="Yearly">
<viz:VizFrame id="yearChart" vizType="column"/>
</Panel>

</HBox>

</VBox>
</Page>
</mvc:View>





sap.ui.define([
"sap/ui/core/mvc/Controller"
], function (Controller) {
"use strict";

return Controller.extend("mfuanalytics.controller.mfureport", {

onAfterRendering: function () {

this.createMainChart();
this.createPieChart();
this.createMonthChart();
this.createQuarterChart();
this.createYearChart();

},

/* ===== MAIN ===== */
createMainChart: function () {

var oChart = this.byId("mainChart");

oChart.setVizProperties({
plotArea: {
data: [
{ Module: "Retail", Value: 30 },
{ Module: "Finance", Value: 55 },
{ Module: "HR", Value: 20 },
{ Module: "IT", Value: 40 }
]
}
});

},

/* ===== PIE ===== */
createPieChart: function () {

var oChart = this.byId("pieChart");

oChart.setVizProperties({
plotArea: {
data: [
{ Type: "Retail", Value: 40 },
{ Type: "Finance", Value: 25 },
{ Type: "HR", Value: 20 },
{ Type: "IT", Value: 15 }
]
}
});

},

/* ===== MONTH ===== */
createMonthChart: function () {

var oChart = this.byId("monthChart");

oChart.setVizProperties({
plotArea: {
data: [
{ Month: "Jan", Value: 20 },
{ Month: "Feb", Value: 30 },
{ Month: "Mar", Value: 50 }
]
}
});

},

/* ===== QUARTER ===== */
createQuarterChart: function () {

var oChart = this.byId("quarterChart");

oChart.setVizProperties({
plotArea: {
data: [
{ Quarter: "Q1", Value: 70 },
{ Quarter: "Q2", Value: 50 },
{ Quarter: "Q3", Value: 30 }
]
}
});

},

/* ===== YEAR ===== */
createYearChart: function () {

var oChart = this.byId("yearChart");

oChart.setVizProperties({
plotArea: {
data: [
{ Year: "2022", Value: 80 },
{ Year: "2023", Value: 60 },
{ Year: "2024", Value: 40 }
]
}
});

}

});
});



.sapMPage {
    background: #f4f7fb;
}

.mainContainer {
    padding: 20px;
}

.topContainer {
    display: flex;
    gap: 20px;
}

.kpiSection {
    width: 35%;
}

.kpiGrid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
}

.kpiCard {
    height: 120px;
    border-radius: 12px;
    background: #ffffff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.chartSection {
    width: 65%;
}

.bottomGrid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 15px;
    margin-top: 20px;
}
