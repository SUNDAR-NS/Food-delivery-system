<mvc:View controllerName="mfuanalytics.controller.mfureport"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data">

<Page title="MFU Dashboard">

<VBox class="mainContainer">

<Title text="MFU Analytics Dashboard" level="H2"/>

<!-- TOP SECTION -->
<HBox class="topSection">

    <!-- KPI LEFT -->
    <VBox class="kpiContainer">

        <HBox class="kpiRow">
            <f:Card class="kpiCard">
                <f:content>
                    <VBox class="centerBox">
                        <NumericContent value="71"/>
                        <Text text="Total Uploaded"/>
                    </VBox>
                </f:content>
            </f:Card>

            <f:Card class="kpiCard">
                <f:content>
                    <VBox class="centerBox">
                        <NumericContent value="60"/>
                        <Text text="Approved"/>
                    </VBox>
                </f:content>
            </f:Card>
        </HBox>

        <HBox class="kpiRow">
            <f:Card class="kpiCard">
                <f:content>
                    <VBox class="centerBox">
                        <NumericContent value="115"/>
                        <Text text="Templates"/>
                    </VBox>
                </f:content>
            </f:Card>

            <f:Card class="kpiCard">
                <f:content>
                    <VBox class="centerBox">
                        <NumericContent value="5"/>
                        <Text text="Rejected"/>
                    </VBox>
                </f:content>
            </f:Card>
        </HBox>

    </VBox>

    <!-- MAIN CHART RIGHT -->
    <f:Card class="mainChartCard">
        <f:content>
            <VBox class="chartBox">

                <Title text="MFU Templates by Module"/>

                <viz:VizFrame id="idMainChart" vizType="column" height="100%">

                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{/modules}">
                            <viz.data:dimensions>
                                <viz.data:DimensionDefinition name="Module" value="{module}"/>
                            </viz.data:dimensions>
                            <viz.data:measures>
                                <viz.data:MeasureDefinition name="Approved" value="{approved}"/>
                            </viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>

                </viz:VizFrame>

            </VBox>
        </f:content>
    </f:Card>

</HBox>

<!-- BOTTOM -->
<HBox class="bottomSection">

<f:Card class="smallCard">
<f:content>
<VBox class="chartBox">
<Title text="Distribution"/>

<viz:VizFrame id="idPie" vizType="donut" height="100%">
<viz:dataset>
<viz.data:FlattenedDataset data="{/modules}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{approved}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>
</viz:VizFrame>

</VBox>
</f:content>
</f:Card>

<f:Card class="smallCard">
<f:content>
<VBox class="chartBox">
<Title text="Monthly"/>

<viz:VizFrame id="idMonthly" vizType="column" height="100%">
<viz:dataset>
<viz.data:FlattenedDataset data="{/monthly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Month" value="{month}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>
</viz:VizFrame>

</VBox>
</f:content>
</f:Card>

<f:Card class="smallCard">
<f:content>
<VBox class="chartBox">
<Title text="Quarterly"/>

<viz:VizFrame id="idQuarterly" vizType="column" height="100%">
<viz:dataset>
<viz.data:FlattenedDataset data="{/quarterly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Quarter" value="{quarter}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>
</viz:VizFrame>

</VBox>
</f:content>
</f:Card>

<f:Card class="smallCard">
<f:content>
<VBox class="chartBox">
<Title text="Yearly"/>

<viz:VizFrame id="idYearly" vizType="column" height="100%">
<viz:dataset>
<viz.data:FlattenedDataset data="{/yearly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Year" value="{year}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>
</viz:VizFrame>

</VBox>
</f:content>
</f:Card>

</HBox>

</VBox>
</Page>
</mvc:View>



sap.ui.define([
"sap/ui/core/mvc/Controller",
"sap/ui/model/json/JSONModel",
"sap/viz/ui5/controls/common/feeds/FeedItem"
], function (Controller, JSONModel, FeedItem) {
"use strict";

return Controller.extend("mfuanalytics.controller.mfureport", {

onInit: function () {

    var data = {
        modules: [
            { module: "NFRP", approved: 30 },
            { module: "SCBI", approved: 55 },
            { module: "ESG", approved: 20 },
            { module: "ICON", approved: 40 }
        ],
        monthly: [
            { month: "Jan", value: 10 },
            { month: "Feb", value: 20 },
            { month: "Mar", value: 15 }
        ],
        quarterly: [
            { quarter: "Q1", value: 40 },
            { quarter: "Q2", value: 25 },
            { quarter: "Q3", value: 30 }
        ],
        yearly: [
            { year: "2022", value: 50 },
            { year: "2023", value: 70 },
            { year: "2024", value: 60 }
        ]
    };

    this.getView().setModel(new JSONModel(data));

    this._addFeeds("idMainChart", "Module", "Approved");
    this._addFeeds("idMonthly", "Month", "Value");
    this._addFeeds("idQuarterly", "Quarter", "Value");
    this._addFeeds("idYearly", "Year", "Value");
    this._addFeeds("idPie", "Module", "Value");
},

_addFeeds: function (id, dim, meas) {

    var chart = this.byId(id);
    if (!chart) return;

    chart.removeAllFeeds();

    if (id === "idPie") {
        chart.addFeed(new FeedItem({ uid: "size", type: "Measure", values: [meas] }));
        chart.addFeed(new FeedItem({ uid: "color", type: "Dimension", values: [dim] }));
    } else {
        chart.addFeed(new FeedItem({ uid: "valueAxis", type: "Measure", values: [meas] }));
        chart.addFeed(new FeedItem({ uid: "categoryAxis", type: "Dimension", values: [dim] }));
    }
}

});
});



.mainContainer {
    padding: 20px;
}

/* TOP */
.topSection {
    display: flex;
    gap: 20px;
    margin-top: 20px;
}

/* KPI */
.kpiContainer {
    width: 35%;
}

.kpiRow {
    display: flex;
    gap: 15px;
    margin-bottom: 15px;
}

.kpiCard {
    flex: 1;
    height: 120px;
}

.centerBox {
    height: 100%;
    justify-content: center;
    align-items: center;
}

/* MAIN CHART */
.mainChartCard {
    width: 65%;
    height: 260px;
}

/* BOTTOM */
.bottomSection {
    display: flex;
    gap: 15px;
    margin-top: 20px;
}

.smallCard {
    flex: 1;
    height: 220px;
}

/* CHART */
.sapVizFrame {
    width: 100% !important;
    height: 100% !important;
}
