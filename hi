onHeaderClick: function (oEvent) {

    var oVBox = oEvent.getSource().getParent();
    var oInput = oVBox.getItems()[1];

    var isVisible = oInput.getVisible();

    // close all first
    this.byId("_IDGenTable").getColumns().forEach(col => {
        var header = col.getHeader();
        if (header instanceof sap.m.VBox) {
            header.getItems()[1].setVisible(false);
        }
    });

    // toggle
    oInput.setVisible(!isVisible);

    // focus
    if (!isVisible) {
        setTimeout(() => oInput.focus(), 100);
    }
}
