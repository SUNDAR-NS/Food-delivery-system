using com.scb.fileupload.master as db from '../db/schema';

service MFUService {

    action getDashboardData(module: array of String) returns {
        uploaded        : Integer;
        approved        : Integer;
        rejected        : Integer;
        totalTemplates  : Integer;
        modules         : array of {
            module   : String;
            uploaded : Integer;
            approved : Integer; 
            rejected : Integer;
        };
        table           : array of {
            module    : String;
            subModule : String;
            loadType  : String;
            template  : String;
            count     : Integer;
        };
    };

    function getModules() returns array of {
        module : String;
    };

    // 🔥 ONLY FOR SANKEY
    function getSankeyData() returns array of {
        period    : String;
        module    : String;
        value     : Integer;
        templates : array of {
            name  : String;
            value : Integer;
        };

    function getPieData() returns many {
    user  : String;
    count : Integer;
};

    };
}
