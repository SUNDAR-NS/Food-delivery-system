<Panel class="moduleFilterBox">
    
    <HBox class="filterRow" alignItems="Center" justifyContent="SpaceBetween">

        <!-- MODULE -->
        <VBox class="filterItem">
            <Text text="Module" class="filterLabel"/>
            <MultiComboBox
                id="moduleFilter"
                width="180px"
                selectionFinish="onFilterChange"
                items="{/allModules}">
                <core:Item key="{module}" text="{module}" />
            </MultiComboBox>
        </VBox>

        <!-- STATUS -->
        <VBox class="filterItem">
            <Text text="Status" class="filterLabel"/>
            <MultiComboBox
                id="statusFilter"
                width="180px"
                selectionFinish="onFilterChange"
                items="{/statusList}">
                <core:Item key="{key}" text="{text}" />
            </MultiComboBox>
        </VBox>

        <!-- USER -->
        <VBox class="filterItem">
            <Text text="User" class="filterLabel"/>
            <MultiComboBox
                id="userFilter"
                width="180px"
                selectionFinish="onFilterChange"
                items="{/userList}">
                <core:Item key="{key}" text="{text}" />
            </MultiComboBox>
        </VBox>

        <!-- DATE -->
        <VBox class="filterItem">
            <Text text="Created Date" class="filterLabel"/>
            <MultiComboBox
                id="dateFilter"
                width="200px"
                selectionFinish="onFilterChange"
                items="{/dateList}">
                <core:Item key="{key}" text="{text}" />
            </MultiComboBox>
        </VBox>

    </HBox>

</Panel>



/* FILTER CONTAINER */
.moduleFilterBox {
    margin-bottom: 15px;
    border-radius: 12px;
    background: white;
    padding: 15px 20px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.08);
}

/* FORCE SINGLE ROW */
.filterRow {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

/* EACH FILTER BLOCK */
.filterItem {
    display: flex;
    flex-direction: column;
    gap: 5px;
}

/* LABEL */
.filterLabel {
    font-weight: 600;
}

/* DROPDOWN SIZE CONTROL */
.sapMMultiComboBox {
    min-width: 150px;
}
