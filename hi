sap.ui.define([
    "sap/ui/core/mvc/Controller",
    "sap/ui/model/json/JSONModel",
    "sap/m/Token"
], function (Controller, JSONModel, Token) {
    "use strict";

    return Controller.extend("mfuanalytics.controller.mfureport", {

        onInit: function () {

            var oModel = new JSONModel({
                allModules: [],
                modules: [],
                tableData: [],
                totalUploaded: 0,
                totalApproved: 0,
                totalRejected: 0,
                totalTemplates: 0
            });

            this.getView().setModel(oModel);

            fetch("/odata/v4/mfu/getModules()")
                .then(res => res.json())
                .then(data => {

                    oModel.setProperty("/allModules", data.value);

                    const allKeys = data.value.map(m => m.module);
                    const oMulti = this.byId("moduleFilter");

                    oMulti.setSelectedKeys(allKeys);

                    // 🔥 SAFE DISPLAY FIX
                    setTimeout(() => {
                        this._applyCompactView();
                    }, 200);

                    this.loadDashboard(allKeys);
                });
        },

        loadDashboard: function (modules) {

            fetch("/odata/v4/mfu/getDashboardData", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ module: modules })
            })
            .then(res => res.json())
            .then(data => {

                var oModel = this.getView().getModel();

                oModel.setProperty("/modules", data.modules || []);
                oModel.setProperty("/tableData", data.table || []);
                oModel.setProperty("/totalUploaded", data.uploaded || 0);
                oModel.setProperty("/totalApproved", data.approved || 0);
                oModel.setProperty("/totalRejected", data.rejected || 0);
                oModel.setProperty("/totalTemplates", data.totalTemplates || 0);

                this._applyChartSettings();
            });
        },

        onFilterChange: function (oEvent) {

            const keys = oEvent.getSource().getSelectedKeys();

            setTimeout(() => {
                this._applyCompactView();
            }, 0);

            if (!keys || keys.length === 0) {
                this.loadDashboard([]);
            } else {
                this.loadDashboard(keys);
            }
        },

        // 🔥 SAFE COMPACT VIEW (NO BREAK)
        _applyCompactView: function () {

            const oMulti = this.byId("moduleFilter");
            const tokens = oMulti.getTokens();

            if (!tokens || tokens.length <= 1) return;

            const firstToken = tokens[0];
            const moreCount = tokens.length - 1;

            // hide remaining tokens (UI only)
            tokens.forEach((t, i) => {
                if (i > 0) {
                    t.getDomRef()?.style && (t.getDomRef().style.display = "none");
                }
            });

            // update first token text
            if (firstToken && moreCount > 0) {
                firstToken.setText(firstToken.getText() + " +" + moreCount + " more");
            }
        },

        _applyChartSettings: function () {

            var oChart = this.byId("idVizFrame");

            if (oChart) {
                oChart.setVizProperties({
                    title: { visible: false },
                    plotArea: {
                        colorPalette: [
                            "#0070f2",
                            "#107e3e",
                            "#bb0000"
                        ]
                    },
                    interaction: {
                        tooltip: { visible: true }
                    }
                });
            }
        }

    });
});
