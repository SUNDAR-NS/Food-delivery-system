using com.scb.fileupload.master as db from '../db/schema';

service MFUService {

    action getDashboardData(module: array of String) returns {
        uploaded        : Integer;
        approved        : Integer;
        rejected        : Integer;
        totalTemplates  : Integer;
        modules         : array of {
            module   : String;
            uploaded : Integer;
            approved : Integer; 
            rejected : Integer;
        };
        table           : array of {
            module    : String;
            subModule : String;
            loadType  : String;
            template  : String;
            count     : Integer;
        };
    };

    function getModules() returns array of {
        module : String;
    };

    // 🔥 ADD THIS (MAIN FIX)
    function getSankeyData() returns array of {
        period    : String;
        module    : String;
        value     : Integer;
        templates : array of {
            name  : String;
            value : Integer;
        };
    };
}





loadSankey: function () {

    fetch("/odata/v4/mfu/getSankeyData()")
        .then(res => res.json())
        .then(data => {

            const result = data.value || []; // ✅ FIX

            const nodesSet = new Set();
            const links = [];

            result.forEach(item => {

                nodesSet.add(item.period);
                nodesSet.add(item.module);

                links.push({
                    source: item.period,
                    target: item.module,
                    value: item.value
                });

                (item.templates || []).forEach(t => {

                    nodesSet.add(t.name);

                    links.push({
                        source: item.module,
                        target: t.name,
                        value: t.value
                    });

                });

            });

            const nodes = Array.from(nodesSet).map(n => ({ name: n }));

            this._renderSankey(nodes, links);
        })
        .catch(err => {
            console.error("SANKEY ERROR:", err);
        });
}
