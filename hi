TRIGGER "COPY_TO_MAIN_TABLE"
AFTER INSERT
ON "T1CLIENTMI_PHY.db::MFU_DICX_LOCATION_STAGE"
REFERENCING NEW ROW NEWROW
FOR EACH ROW
BEGIN

INSERT INTO "T1CLIENTMI_PHY.db::3TL_CLNTMI_ESG_DICX_LOCATION"
(
    "ID",
    "NAME",
    "LOCATION_HIERARCHY",
    "LOCATION_CTRY_DAC_KEY",
    "LATITUDE",
    "LONGITUDE",
    "EXPIRY_DATE"
)
VALUES
(
    SUBSTRING(REPLACE(TO_NVARCHAR(SYSUUID),'-',''),1,18),
    NEWROW."NAME",
    NEWROW."LOCATION_HIERARCHY",
    NEWROW."LOCATION_CTRY_DAC_KEY",
    NEWROW."LATITUDE",
    NEWROW."LONGITUDE",
    NEWROW."EXPIRY_DATE"
);

END;
