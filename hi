<viz:VizFrame
    id="mfuTreemap"
    vizType="treemap"
    width="100%"
    height="500px"
    vizProperties='{
        "title": {
            "visible": true,
            "text": "MFU Upload Analytics"
        },
        "plotArea": {
            "dataLabel": {
                "visible": true
            }
        }
    }'>

    <viz:dataset>

        <viz.data:FlattenedDataset id="_IDGenFlattenedDataset" data="{/data}">

            <viz.data:dimensions>

                <viz.data:DimensionDefinition id="_IDGenDimensionDefinition" name="Module" value="{module}"/>
                <viz.data:DimensionDefinition id="_IDGenDimensionDefinition5" name="Submodule" value="{submodule}"/>
                <viz.data:DimensionDefinition id="_IDGenDimensionDefinition6" name="Template" value="{template}"/>
                <viz.data:DimensionDefinition id="_IDGenDimensionDefinition7" name="Status" value="{status}"/>

            </viz.data:dimensions>

            <viz.data:measures>

                <viz.data:MeasureDefinition id="_IDGenMeasureDefinition" name="MFU Count" value="{value}"/>

            </viz.data:measures>

        </viz.data:FlattenedDataset>

    </viz:dataset>

    <viz:feeds>

        <!-- hierarchy -->
        <viz.feeds:FeedItem id="_IDGenFeedItem1"
            uid="categoryAxis"
            type="Dimension"
            values="Module,Submodule,Template,Status"/>

        <!-- rectangle size -->
        <viz.feeds:FeedItem id="_IDGenFeedItem10"
            uid="size"
            type="Measure"
            values="MFU Count"/>

        <!-- color by status -->
        <viz.feeds:FeedItem id="_IDGenFeedItem11"
            uid="color"
            type="Dimension"
            values="Status"/>

    </viz:feeds>

</viz:VizFrame>


