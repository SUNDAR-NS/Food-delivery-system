{
  "sequence": {
    "name": "SEQ_LOCATION_ID",
    "startWith": 1,
    "incrementBy": 1,
    "minValue": 1,
    "maxValue": 999999999999,
    "cache": 1,
    "cycle": false
  }
}



TRIGGER "AUTO_ID_TRIGGER"
BEFORE INSERT ON "T1CLIENTMI_PHY.db::3TL_CLNTMI_ESG_DICX_LOCATION"
REFERENCING NEW ROW AS NEW
FOR EACH ROW
BEGIN
    SELECT TO_NVARCHAR("SEQ_LOCATION_ID".NEXTVAL)
    INTO :NEW."ID"
    FROM DUMMY;
END;



VIEW "T1CLIENTMI_PHY.db::MFU_VIEW" AS
SELECT 
  "MFU_ID" AS "ID",
  "NAME",
  "LOCATION_HIERARCHY",
  "LOCATION_CTRY_DAC_KEY",
  "LATITUDE",
  "LONGITUDE",
  "EXPIRY_DATE"
FROM "T1CLIENTMI_PHY.db::3TL_CLNTMI_ESG_DICX_LOCATION";



{
  "MFU_DICX_LOCATION": {
    "target": {
      "object": "T1CLIENTMI_PHY.db::MFU_VIEW"
    }
  }
}
