<mvc:View controllerName="mfuanalytics.controller.mfureport"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

<Page title="MFU Dashboard">

<VBox class="mainContainer">

<Title text="MFU Analytics Dashboard" level="H2"/>

<!-- TOP SECTION -->
<HBox class="topSection" renderType="Bare">

    <!-- LEFT KPI -->
    <VBox class="kpiContainer">

        <HBox class="kpiRow">
            <f:Card class="kpiCard">
                <f:content>
                    <VBox class="centerBox">
                        <NumericContent value="71" valueColor="Good"/>
                        <Text text="Total Uploaded"/>
                    </VBox>
                </f:content>
            </f:Card>

            <f:Card class="kpiCard">
                <f:content>
                    <VBox class="centerBox">
                        <NumericContent value="60" valueColor="Good"/>
                        <Text text="Approved"/>
                    </VBox>
                </f:content>
            </f:Card>
        </HBox>

        <HBox class="kpiRow">
            <f:Card class="kpiCard">
                <f:content>
                    <VBox class="centerBox">
                        <NumericContent value="115"/>
                        <Text text="Templates"/>
                    </VBox>
                </f:content>
            </f:Card>

            <f:Card class="kpiCard">
                <f:content>
                    <VBox class="centerBox">
                        <NumericContent value="5" valueColor="Error"/>
                        <Text text="Rejected"/>
                    </VBox>
                </f:content>
            </f:Card>
        </HBox>

    </VBox>

    <!-- RIGHT MAIN CHART -->
    <f:Card class="mainChartCard">
        <f:content>
            <VBox class="chartBox">

                <Title text="MFU Templates by Module" level="H5"/>

                <viz:VizFrame vizType="column" height="100%">

                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{/modules}">
                            <viz.data:dimensions>
                                <viz.data:DimensionDefinition name="Module" value="{module}"/>
                            </viz.data:dimensions>
                            <viz.data:measures>
                                <viz.data:MeasureDefinition name="Approved" value="{approved}"/>
                            </viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>

                    <viz:feeds>
                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Approved"/>
                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Module"/>
                    </viz:feeds>

                </viz:VizFrame>

            </VBox>
        </f:content>
    </f:Card>

</HBox>


<!-- BOTTOM CHARTS -->
<HBox class="bottomSection" renderType="Bare">

<f:Card class="smallCard">
<f:content>
<VBox class="chartBox">
<Title text="Distribution"/>

<viz:VizFrame vizType="donut" height="100%">
<viz:dataset>
<viz.data:FlattenedDataset data="{/modules}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{approved}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>
<viz:feeds>
<viz.feeds:FeedItem uid="size" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="color" type="Dimension" values="Module"/>
</viz:feeds>
</viz:VizFrame>

</VBox>
</f:content>
</f:Card>

<f:Card class="smallCard">
<f:content>
<VBox class="chartBox">
<Title text="Monthly"/>

<viz:VizFrame vizType="column" height="100%">
<viz:dataset>
<viz.data:FlattenedDataset data="{/monthly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Month" value="{month}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>
<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month"/>
</viz:feeds>
</viz:VizFrame>

</VBox>
</f:content>
</f:Card>

<f:Card class="smallCard">
<f:content>
<VBox class="chartBox">
<Title text="Quarterly"/>

<viz:VizFrame vizType="column" height="100%">
<viz:dataset>
<viz.data:FlattenedDataset data="{/quarterly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Quarter" value="{quarter}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>
<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
<viz:feeds:FeedItem uid="categoryAxis" type="Dimension" values="Quarter"/>
</viz:feeds>
</viz:VizFrame>

</VBox>
</f:content>
</f:Card>

<f:Card class="smallCard">
<f:content>
<VBox class="chartBox">
<Title text="Yearly"/>

<viz:VizFrame vizType="column" height="100%">
<viz:dataset>
<viz.data:FlattenedDataset data="{/yearly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Year" value="{year}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>
<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Year"/>
</viz:feeds>
</viz:VizFrame>

</VBox>
</f:content>
</f:Card>

</HBox>

</VBox>
</Page>
</mvc:View>



.mainContainer {
    padding: 20px;
}

/* TOP LAYOUT */
.topSection {
    display: flex;
    gap: 20px;
    margin-top: 20px;
}

/* KPI SIDE */
.kpiContainer {
    width: 35%;
}

/* KPI ROW */
.kpiRow {
    display: flex;
    gap: 15px;
    margin-bottom: 15px;
}

/* KPI CARD */
.kpiCard {
    flex: 1;
    height: 120px;
}

/* CENTER CONTENT */
.centerBox {
    height: 100%;
    justify-content: center;
    align-items: center;
}

/* MAIN CHART */
.mainChartCard {
    width: 65%;
    height: 260px;
}

/* CHART BOX */
.chartBox {
    height: 100%;
}

/* BOTTOM SECTION */
.bottomSection {
    display: flex;
    gap: 15px;
    margin-top: 20px;
}

/* SMALL CARDS */
.smallCard {
    flex: 1;
    height: 220px;
}

/* CHART FULL */
.sapVizFrame {
    width: 100% !important;
    height: 100% !important;
}
