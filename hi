<Panel headerText="MFU Drill Down">

<viz:VizFrame
    id="idTreemap"
    vizType="treemap"
    height="400px"
    selectData="onTreemapSelect"
    vizProperties='{
        "title":{"visible":false},
        "plotArea":{"dataLabel":{"visible":true}}
    }'>

    <viz:dataset>
        <viz.data:FlattenedDataset data="{/treeData}">

            <viz.data:dimensions>
                <viz.data:DimensionDefinition name="Name" value="{name}"/>
            </viz.data:dimensions>

            <viz.data:measures>
                <viz.data:MeasureDefinition name="Count" value="{value}"/>
            </viz.data:measures>

        </viz.data:FlattenedDataset>
    </viz:dataset>

    <viz:feeds>

        <!-- REQUIRED -->
        <viz.feeds:FeedItem uid="categoryAxis"
            type="Dimension"
            values="Name"/>

        <!-- REQUIRED -->
        <viz.feeds:FeedItem uid="size"
            type="Measure"
            values="Count"/>

        <!-- 🔥 THIS FIXES YOUR ERROR -->
        <viz.feeds:FeedItem uid="color"
            type="Dimension"
            values="Name"/>

    </viz:feeds>

</viz:VizFrame>

<!-- BUTTONS -->
<HBox>
    <Button text="⬅ Back" press="onBackDrill"/>
    <Button text="Reset" press="onResetTreemap"/>
</HBox>

</Panel>
