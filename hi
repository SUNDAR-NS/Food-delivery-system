<columns>

    <!-- Module -->
    <Column>
        <VBox>
            <Text text="Module"
                  visible="{= !${view>/filterMode} }"/>
            <Input visible="{view>/filterMode}"
                   liveChange="onTableFilter"
                   placeholder="module"/>
        </VBox>
    </Column>

    <!-- Sub Module -->
    <Column>
        <VBox>
            <Text text="Sub Module"
                  visible="{= !${view>/filterMode} }"/>
            <Input visible="{view>/filterMode}"
                   liveChange="onTableFilter"
                   placeholder="subModule"/>
        </VBox>
    </Column>

    <!-- Load Type -->
    <Column>
        <VBox>
            <Text text="Load Type"
                  visible="{= !${view>/filterMode} }"/>
            <Input visible="{view>/filterMode}"
                   liveChange="onTableFilter"
                   placeholder="loadType"/>
        </VBox>
    </Column>

    <!-- Template -->
    <Column>
        <VBox>
            <Text text="Template"
                  visible="{= !${view>/filterMode} }"/>
            <Input visible="{view>/filterMode}"
                   liveChange="onTableFilter"
                   placeholder="template"/>
        </VBox>
    </Column>

    <!-- Count -->
    <Column>
        <Text text="Load Count"/>
    </Column>

</columns>





onTableFilter: function () {

    var oTable = this.byId("_IDGenTable");
    var oBinding = oTable.getBinding("items");

    var aFilters = [];

    oTable.getColumns().forEach(col => {

        var header = col.getHeader();

        if (header instanceof sap.m.VBox) {

            var input = header.getItems()[1];
            var value = input.getValue();

            if (value) {

                var field = input.getPlaceholder(); // 🔥 direct field name

                aFilters.push(new sap.ui.model.Filter(
                    field,
                    sap.ui.model.FilterOperator.Contains,
                    value
                ));
            }
        }
    });

    oBinding.filter(aFilters);
}



onAfterRendering: function () {

    this.loadSankey();

    var oTable = this.byId("_IDGenTable");

    oTable.getColumns().forEach(col => {

        var header = col.getHeader();

        if (header instanceof sap.m.VBox) {

            var text = header.getItems()[0];

            text.addEventDelegate({
                ondblclick: () => {
                    this.onEnableFilter();
                }
            });
        }
    });
}
