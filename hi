using com.scb.fileupload.master as db from '../db/schema';

service MFUService {

    // 🔥 MAIN DASHBOARD
    action getDashboardData(module: array of String) returns {
        uploaded        : Integer;
        approved        : Integer;
        pending         : Integer;
        totalTemplates  : Integer;
        modules         : array of {
            module   : String;
            uploaded : Integer;
            approved : Integer; 
            pending  : Integer;
        };
        table           : array of {
            module      : String;
            subModule   : String;
            template    : String;
            status      : String;
            user        : String;
        };
    };

    function getModules() returns array of {
        module : String;
    };

}







sap.ui.define([
    "sap/ui/core/mvc/Controller",
    "sap/ui/model/json/JSONModel"
], function (Controller, JSONModel) {
    "use strict";

    return Controller.extend("mfuanalytics.controller.mfureport", {

        onInit: function () {

            this._showTreemap = false;

            var oModel = new JSONModel({
                allModules: [],
                modules: [],
                tableData: [],
                totalUploaded: 0,
                totalApproved: 0,
                totalRejected: 0,
                totalTemplates: 0
            });

            this.getView().setModel(oModel);

            setTimeout(() => {
                document.activeElement.blur();
            }, 100);

            fetch("/odata/v4/mfu/getModules()")
                .then(res => res.json())
                .then(data => {

                    oModel.setProperty("/allModules", data.value);

                    const allKeys = data.value.map(m => m.module);

                    this.byId("_IDGenMultiComboBox1").setSelectedKeys(allKeys);

                    this.loadDashboard(allKeys);
                    this.loadSankey(); // 🔥 ADD THIS
                });
        },

        // 🔥 SANKEY LOAD
        loadSankey: function () {

            fetch("/odata/v4/mfu/getSankeyData()")
                .then(res => res.json())
                .then(data => {

                    const result = data.value;

                    const nodesSet = new Set();
                    const links = [];

                    result.forEach(item => {

                        nodesSet.add(item.period);
                        nodesSet.add(item.module);

                        links.push({
                            source: item.period,
                            target: item.module,
                            value: item.value
                        });

                        item.templates.forEach(t => {

                            nodesSet.add(t.name);

                            links.push({
                                source: item.module,
                                target: t.name,
                                value: t.value
                            });

                        });

                    });

                    const nodes = Array.from(nodesSet).map(n => ({ name: n }));

                    this._renderSankey(nodes, links);
                });
        },

        _renderSankey: function (nodes, links) {

            var chartDom = document.getElementById("sankeyChart");
            if (!chartDom) return;

            var chart = echarts.init(chartDom);

            var option = {
                tooltip: {
                    trigger: "item"
                },
                series: [
                    {
                        type: "sankey",
                        data: nodes,
                        links: links,
                        nodeAlign: "left",
                        lineStyle: {
                            curveness: 0.5
                        },
                        emphasis: {
                            focus: "adjacency"
                        }
                    }
                ]
            };

            chart.setOption(option);
        },

        onToggleChart: function (oEvent) {

            this._showTreemap = !this._showTreemap;

            this.byId("vizContainer").setVisible(!this._showTreemap);
            this.byId("treemapContainer").setVisible(this._showTreemap);

            oEvent.getSource().setText(
                this._showTreemap ? "Chart" : "Treemap"
            );

            if (this._showTreemap) {
                setTimeout(this._renderTreemap.bind(this), 200);
            }
        },

        onFilterChange: function (oEvent) {

            const keys = oEvent.getSource().getSelectedKeys();

            if (!keys || keys.length === 0) {
                this.loadDashboard([]);
            } else {
                this.loadDashboard(keys);
            }
        },

        loadDashboard: function (modules) {

            fetch("/odata/v4/mfu/getDashboardData", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    module: modules
                })
            })
            .then(res => res.json())
            .then(data => {

                var oModel = this.getView().getModel();

                oModel.setProperty("/modules", data.modules || []);
                oModel.setProperty("/tableData", data.table || []);
                oModel.setProperty("/totalUploaded", data.uploaded || 0);
                oModel.setProperty("/totalApproved", data.approved || 0);
                oModel.setProperty("/totalRejected", data.rejected || 0);
                oModel.setProperty("/totalTemplates", data.totalTemplates || 0);
            });
        }

    });
});





const cds = require('@sap/cds');

module.exports = cds.service.impl(async function () {

    const { ReportFileStorage, TemplateStorage } = cds.entities('com.scb.fileupload.master');

    // GET MODULE DROPDOWN
    this.on('getModules', async () => {

        const data = await cds.run(
            SELECT.distinct.from(TemplateStorage).columns('MODULE_NAME').orderBy('MODULE_NAME')
        );

        return data.map(d => ({
            module: d.MODULE_NAME
        }));
    });

    // MAIN DASHBOARD
    this.on('getDashboardData', async (req) => {

        let modules = req.data.module || [];

        if (typeof modules === "string") {
            modules = [modules];
        }

        let reportData = [];
        let templateData = [];

        if (modules.length > 0) {

            reportData = await cds.run(
                SELECT.from(ReportFileStorage)
                    .where({ MODULE_NAME: { in: modules } })
            );

            templateData = await cds.run(
                SELECT.from(TemplateStorage)
                    .where({ MODULE_NAME: { in: modules } })
            );

        } else {
            reportData = await cds.run(SELECT.from(ReportFileStorage));
            templateData = await cds.run(SELECT.from(TemplateStorage));
        }

        let uploaded = 0, approved = 0, rejected = 0;

        reportData.forEach(r => {
            if (r.STATUS === 'uploaded') uploaded++;
            if (r.STATUS === 'approved') approved++;
            if (r.STATUS === 'rejected') rejected++;
        });

        const moduleMap = {};

        reportData.forEach(r => {

            if (!moduleMap[r.MODULE_NAME]) {
                moduleMap[r.MODULE_NAME] = {
                    module: r.MODULE_NAME,
                    uploaded: 0,
                    approved: 0,
                    rejected: 0
                };
            }

            if (r.STATUS === 'uploaded') moduleMap[r.MODULE_NAME].uploaded++;
            if (r.STATUS === 'approved') moduleMap[r.MODULE_NAME].approved++;
            if (r.STATUS === 'rejected') moduleMap[r.MODULE_NAME].rejected++;
        });

        const modulesData = Object.values(moduleMap);

        const tableMap = {};

        reportData.forEach(r => {

            const key = `${r.MODULE_NAME}_${r.SUB_MODULE_NAME}_${r.LOAD_TYPE}_${r.LOAD_TEMPLATE}`;

            if (!tableMap[key]) {
                tableMap[key] = {
                    module: r.MODULE_NAME,
                    subModule: r.SUB_MODULE_NAME,
                    loadType: r.LOAD_TYPE,
                    template: r.LOAD_TEMPLATE,
                    count: 0
                };
            }

            tableMap[key].count++;
        });

        const table = Object.values(tableMap);
        const totalTemplates = templateData.length;

        return {
            uploaded,
            approved,
            rejected,
            totalTemplates,
            modules: modulesData,
            table
        };
    });

    // 🔥 SANKEY DATA (NEW)
    this.on('getSankeyData', async () => {

        const today = new Date();

        const startOfMonth = new Date(today.getFullYear(), today.getMonth(), 1);

        const startOfQuarter = new Date(today);
        startOfQuarter.setMonth(today.getMonth() - 2);
        startOfQuarter.setDate(1);

        const startOfYear = new Date(today);
        startOfYear.setFullYear(today.getFullYear() - 1);

        const reportData = await cds.run(SELECT.from(ReportFileStorage));

        function process(data, periodName) {

            const moduleMap = {};

            data.forEach(r => {

                const module = r.MODULE_NAME;
                const template = r.LOAD_TEMPLATE;

                if (!moduleMap[module]) {
                    moduleMap[module] = {
                        count: 0,
                        templates: {}
                    };
                }

                moduleMap[module].count++;

                if (!moduleMap[module].templates[template]) {
                    moduleMap[module].templates[template] = 0;
                }

                moduleMap[module].templates[template]++;
            });

            const topModules = Object.entries(moduleMap)
                .sort((a, b) => b[1].count - a[1].count)
                .slice(0, 3);

            const result = [];

            topModules.forEach(([moduleName, moduleData]) => {

                const topTemplates = Object.entries(moduleData.templates)
                    .sort((a, b) => b[1] - a[1])
                    .slice(0, 3);

                result.push({
                    period: periodName,
                    module: moduleName,
                    value: moduleData.count,
                    templates: topTemplates.map(t => ({
                        name: t[0],
                        value: t[1]
                    }))
                });

            });

            return result;
        }

        const monthly = reportData.filter(r => new Date(r.CREATEDAT) >= startOfMonth);
        const quarterly = reportData.filter(r => new Date(r.CREATEDAT) >= startOfQuarter);
        const yearly = reportData.filter(r => new Date(r.CREATEDAT) >= startOfYear);

        return [
            ...process(monthly, "Monthly"),
            ...process(quarterly, "Quarterly"),
            ...process(yearly, "Yearly")
        ];
    });

});
