service MFUService {
    
    // 🔥 MAIN DASHBOARD
    action getDashboardData(module: array of String) returns {
        uploaded        : Integer;
        approved        : Integer;
        pending         : Integer;
        totalTemplates  : Integer;
        modules         : array of {
            module   : String;
            uploaded : Integer;
            approved : Integer; 
            pending  : Integer;
        };
        table           : array of {
            module      : String;
            subModule   : String;
            template    : String;
            status      : String;
            user        : String;
        };
        uploadedmodules   : array of {
            MODULE_NAME   : String;
            SUB_MODULE_NAME : Integer;
            LOAD_TEMPLATE : Integer;
        };
        approvedmodules   : array of {
            MODULE_NAME   : String;
            SUB_MODULE_NAME : Integer;
            LOAD_TEMPLATE : Integer;
            createdBy : String;
            createdAt : Timestamp;
            modifiedBy : Timestamp;
        };
        rejectedmodules   : array of {
            MODULE_NAME   : String;
            SUB_MODULE_NAME : Integer;
            LOAD_TEMPLATE : Integer;
            CREATED_BY: String;
            CREATED_AT: Timestamp;
            MODIFIED_BY: Timestamp;
        };
    };

    function getModules() returns array of {
        module : String;
    };

    function getSankeyData() returns many {

        period    : String;

        module    : String;

        value     : Integer;

        templates : many {

            name  : String;

            value : Integer;

        };

        function getPieData() returns many {
            user : String;
            count : Integer;
        };

    };
}






