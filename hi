<Panel class="moduleFilterBox">
    
    <HBox class="filterRow" justifyContent="Start" alignItems="Center" wrap="Wrap">

        <!-- MODULE -->
        <HBox alignItems="Center" class="singleFilter">
            <Text text="Module" class="filterLabel"/>
            <MultiComboBox
                id="moduleFilter"
                width="160px"
                selectionFinish="onFilterChange"
                items="{/allModules}">
                <core:Item key="{module}" text="{module}" />
            </MultiComboBox>
        </HBox>

        <!-- STATUS -->
        <HBox alignItems="Center" class="singleFilter">
            <Text text="Status" class="filterLabel"/>
            <MultiComboBox
                id="statusFilter"
                width="160px"
                selectionFinish="onFilterChange"
                items="{/statusList}">
                <core:Item key="{key}" text="{text}" />
            </MultiComboBox>
        </HBox>

        <!-- USER -->
        <HBox alignItems="Center" class="singleFilter">
            <Text text="User" class="filterLabel"/>
            <MultiComboBox
                id="userFilter"
                width="160px"
                selectionFinish="onFilterChange"
                items="{/userList}">
                <core:Item key="{key}" text="{text}" />
            </MultiComboBox>
        </HBox>

        <!-- DATE -->
        <HBox alignItems="Center" class="singleFilter">
            <Text text="Created Date" class="filterLabel"/>
            <MultiComboBox
                id="dateFilter"
                width="180px"
                selectionFinish="onFilterChange"
                items="{/dateList}">
                <core:Item key="{key}" text="{text}" />
            </MultiComboBox>
        </HBox>

    </HBox>

</Panel>
