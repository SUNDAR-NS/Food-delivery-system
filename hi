<viz:VizFrame 
    id="_IDGenVizFrame1" 
    vizType="donut" 
    height="220px" 
    width="100%"
    vizProperties='{
        "title": { "visible": false },

        "legend": {
            "visible": true,
            "position": "right"
        },

        "plotArea": {
            "dataLabel": {
                "visible": true,
                "type": "percentage"
            },
            "innerRadius": "60%",
            "colorPalette": [
                "#0a6ed1",
                "#107e3e",
                "#e9730c",
                "#bb0000"
            ]
        },

        "interaction": {
            "selectability": {
                "mode": "SINGLE"
            }
        }
    }'>
    
    <viz:dataset>
        <viz.data:FlattenedDataset data="{/pieModules}">
            <viz.data:dimensions>
                <viz.data:DimensionDefinition name="User" value="{user}"/>
            </viz.data:dimensions>

            <viz.data:measures>
                <viz.data:MeasureDefinition name="Templates" value="{count}"/>
            </viz.data:measures>
        </viz.data:FlattenedDataset>
    </viz:dataset>

    <viz:feeds>
        <viz.feeds:FeedItem uid="size" type="Measure" values="Templates"/>
        <viz.feeds:FeedItem uid="color" type="Dimension" values="User"/>
    </viz:feeds>

</viz:VizFrame>
