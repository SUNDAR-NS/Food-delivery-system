
<columns>

    <!-- Module -->
    <Column>
        <VBox>
            <Text text="Module"
                  visible="{= !${view>/filterMode} }"
                  press="onEnableFilter"/>
            <Input visible="{view>/filterMode}"
                   liveChange="onTableFilter"
                   placeholder="Search Module"/>
        </VBox>
    </Column>

    <!-- Sub Module -->
    <Column>
        <VBox>
            <Text text="Sub Module"
                  visible="{= !${view>/filterMode} }"
                  press="onEnableFilter"/>
            <Input visible="{view>/filterMode}"
                   liveChange="onTableFilter"
                   placeholder="Search SubModule"/>
        </VBox>
    </Column>

    <!-- Load Type -->
    <Column>
        <VBox>
            <Text text="Load Type"
                  visible="{= !${view>/filterMode} }"
                  press="onEnableFilter"/>
            <Input visible="{view>/filterMode}"
                   liveChange="onTableFilter"
                   placeholder="Search LoadType"/>
        </VBox>
    </Column>

    <!-- Template -->
    <Column>
        <VBox>
            <Text text="Template"
                  visible="{= !${view>/filterMode} }"
                  press="onEnableFilter"/>
            <Input visible="{view>/filterMode}"
                   liveChange="onTableFilter"
                   placeholder="Search Template"/>
        </VBox>
    </Column>

    <!-- Count -->
    <Column>
        <Text text="Load Count"/>
    </Column>

</columns>
