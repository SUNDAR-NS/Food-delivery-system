mfureport.view.xml

<mvc:View controllerName="mfuanalytics.controller.mfureport"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:layout="sap.ui.layout">
<Page id="page" title="MFU Dashboard">

<VBox id="_IDGenVBox1" class="sapUiSmallMargin">

<!-- KPI CARDS -->
<HBox id="_IDGenHBox" justifyContent="SpaceBetween">

<GenericTile id="_IDGenGenericTile" header="Total MFU Uploaded">
<TileContent id="_IDGenTileContent">
<NumericContent id="_IDGenNumericContent" value="71"/>
</TileContent>
</GenericTile>

<GenericTile id="_IDGenGenericTile1" header="Total MFU Approved">
<TileContent id="_IDGenTileContent1">
<NumericContent id="_IDGenNumericContent1" value="60"/>
</TileContent>
</GenericTile>

<GenericTile id="_IDGenGenericTile2" header="MFU Template Onboarded">
<TileContent id="_IDGenTileContent2">
<NumericContent id="_IDGenNumericContent2" value="115"/>
</TileContent>
</GenericTile>

<GenericTile id="_IDGenGenericTile3" header="Total MFU Rejected">
<TileContent id="_IDGenTileContent3">
<NumericContent id="_IDGenNumericContent3" value="5"/>
</TileContent>
</GenericTile>

</HBox>


<!-- MAIN CHART -->
<Panel id="_IDGenPanel" headerText="MFU Templates by Modules" class="sapUiMediumMarginTop">

<viz:VizFrame
    id="idBarChart"
    vizType="stacked_column"
    width="100%"
    height="400px">

<viz:dataset>
<viz.data:FlattenedDataset id="_IDGenFlattenedDataset" data="{/modules}">
<viz.data:dimensions>
<viz.data:DimensionDefinition id="_IDGenDimensionDefinition" name="Module" value="{module}"/>
</viz.data:dimensions>

<viz.data:measures>
<viz.data:MeasureDefinition id="_IDGenMeasureDefinition" name="Approved" value="{approved}"/>
<viz.data:MeasureDefinition id="_IDGenMeasureDefinition1" name="Pending" value="{pending}"/>
<viz.data:MeasureDefinition id="_IDGenMeasureDefinition2" name="Uploaded" value="{uploaded}"/>
</viz.data:measures>

</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem id="_IDGenFeedItem" uid="valueAxis" type="Measure" values="Approved"/>
<viz.feeds:FeedItem id="_IDGenFeedItem1" uid="valueAxis" type="Measure" values="Pending"/>
<viz.feeds:FeedItem id="_IDGenFeedItem2" uid="valueAxis" type="Measure" values="Uploaded"/>
<viz.feeds:FeedItem id="_IDGenFeedItem3" uid="categoryAxis" type="Dimension" values="Module"/>
</viz:feeds>

</viz:VizFrame>

</Panel>


<!-- LOWER CHARTS -->
<HBox id="_IDGenHBox1" justifyContent="SpaceBetween" class="sapUiMediumMarginTop">

<Panel id="_IDGenPanel1" headerText="Templates by Count" width="32%">
<viz:VizFrame id="_IDGenVizFrame" vizType="pie" height="250px"/>
</Panel>

<Panel id="_IDGenPanel2" headerText="Top 3 Templates (Month)" width="32%">
<viz:VizFrame id="_IDGenVizFrame1" vizType="column" height="250px"/>
</Panel>

<Panel id="_IDGenPanel3" headerText="Top 3 Templates (Quarter)" width="32%">
<viz:VizFrame id="_IDGenVizFrame2" vizType="column" height="250px"/>
</Panel>

</HBox>


<!-- TABLE -->
<Panel id="_IDGenPanel4" headerText="MFU Details" class="sapUiMediumMarginTop">

<Table id="_IDGenTable" items="{/details}">

<columns>
<Column id="_IDGenColumn"><Text id="_IDGenText" text="Module"/></Column>
<Column id="_IDGenColumn1"><Text id="_IDGenText1" text="Sub Module"/></Column>
<Column id="_IDGenColumn2"><Text id="_IDGenText2" text="Load Type"/></Column>
<Column id="_IDGenColumn3"><Text id="_IDGenText3" text="Load Template"/></Column>
<Column id="_IDGenColumn4"><Text id="_IDGenText4" text="Load Count"/></Column>
</columns>

<items>
<ColumnListItem id="_IDGenColumnListItem">
<cells>
<Text id="_IDGenText5" text="{module}"/>
<Text id="_IDGenText6" text="{submodule}"/>
<Text id="_IDGenText7" text="{type}"/>
<Text id="_IDGenText8" text="{template}"/>
<Text id="_IDGenText9" text="{count}"/>
</cells>
</ColumnListItem>
</items>

</Table>

</Panel>

</VBox>

</Page>
</mvc:View>

