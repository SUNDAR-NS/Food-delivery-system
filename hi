<mvc:View controllerName="mfuanalytics.controller.mfureport"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

<Page title="MFU Dashboard">

<VBox class="mainContainer">

<Title text="MFU Analytics Dashboard" level="H2"/>

<!-- KPI CARDS -->
<layout:Grid defaultSpan="L3 M6 S12" class="sapUiMediumMarginTop">

<f:Card>
<f:content>
<VBox class="sapUiSmallMargin">
<NumericContent value="71" valueColor="Good" indicator="Up"/>
<Text text="Total Uploaded"/>
</VBox>
</f:content>
</f:Card>

<f:Card>
<f:content>
<VBox class="sapUiSmallMargin">
<NumericContent value="60" valueColor="Good"/>
<Text text="Approved"/>
</VBox>
</f:content>
</f:Card>

<f:Card>
<f:content>
<VBox class="sapUiSmallMargin">
<NumericContent value="115" valueColor="Neutral"/>
<Text text="Templates"/>
</VBox>
</f:content>
</f:Card>

<f:Card>
<f:content>
<VBox class="sapUiSmallMargin">
<NumericContent value="5" valueColor="Error"/>
<Text text="Rejected"/>
</VBox>
</f:content>
</f:Card>

</layout:Grid>


<!-- MAIN CHART -->
<f:Card class="sapUiMediumMarginTop">
<f:header>
<CardHeader title="MFU Templates by Module"/>
</f:header>

<f:content>
<viz:VizFrame id="idMainChart" vizType="column" height="350px">

<viz:dataset>
<viz.data:FlattenedDataset data="{/modules}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Approved" value="{approved}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Approved"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Module"/>
</viz:feeds>

</viz:VizFrame>
</f:content>
</f:Card>


<!-- BOTTOM CHARTS -->
<layout:Grid defaultSpan="L3 M6 S12" class="sapUiMediumMarginTop">

<!-- PIE -->
<f:Card>
<f:header><CardHeader title="Distribution"/></f:header>
<f:content>
<viz:VizFrame id="idPie" vizType="donut" height="220px">

<viz:dataset>
<viz.data:FlattenedDataset data="{/modules}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{approved}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="size" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="color" type="Dimension" values="Module"/>
</viz:feeds>

</viz:VizFrame>
</f:content>
</f:Card>

<!-- MONTHLY -->
<f:Card>
<f:header><CardHeader title="Monthly Trend"/></f:header>
<f:content>
<viz:VizFrame id="idMonthly" vizType="column" height="220px">

<viz:dataset>
<viz.data:FlattenedDataset data="{/monthly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Month" value="{month}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month"/>
</viz:feeds>

</viz:VizFrame>
</f:content>
</f:Card>

<!-- QUARTERLY -->
<f:Card>
<f:header><CardHeader title="Quarterly"/></f:header>
<f:content>
<viz:VizFrame id="idQuarterly" vizType="column" height="220px">

<viz:dataset>
<viz.data:FlattenedDataset data="{/quarterly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Quarter" value="{quarter}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Quarter"/>
</viz:feeds>

</viz:VizFrame>
</f:content>
</f:Card>

<!-- YEARLY -->
<f:Card>
<f:header><CardHeader title="Yearly"/></f:header>
<f:content>
<viz:VizFrame id="idYearly" vizType="column" height="220px">

<viz:dataset>
<viz.data:FlattenedDataset data="{/yearly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Year" value="{year}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Year"/>
</viz:feeds>

</viz:VizFrame>
</f:content>
</f:Card>

</layout:Grid>


<!-- TABLE -->
<f:Card class="sapUiMediumMarginTop">

<f:header>
<CardHeader title="MFU Details"/>
</f:header>

<f:content>
<Table growing="true" items="{/tableData}">

<headerToolbar>
<Toolbar>
<Title text="Detailed View"/>
<ToolbarSpacer/>
<SearchField width="200px"/>
</Toolbar>
</headerToolbar>

<columns>
<Column><Text text="Module"/></Column>
<Column><Text text="Sub Module"/></Column>
<Column><Text text="Load Type"/></Column>
<Column><Text text="Template"/></Column>
<Column><Text text="Count"/></Column>
</columns>

<items>
<ColumnListItem>
<cells>
<Text text="{module}"/>
<Text text="{submodule}"/>
<Text text="{load}"/>
<Text text="{template}"/>
<Text text="{count}"/>
</cells>
</ColumnListItem>
</items>

</Table>
</f:content>

</f:Card>

</VBox>
</Page>
</mvc:View>






sap.ui.define([
"sap/ui/core/mvc/Controller",
"sap/ui/model/json/JSONModel"
], function (Controller, JSONModel) {
"use strict";

return Controller.extend("mfuanalytics.controller.mfureport", {

onInit: function () {

    var data = {

        modules: [
            { module: "NFRP", approved: 30 },
            { module: "SCBI", approved: 55 },
            { module: "ESG", approved: 20 },
            { module: "ICON", approved: 40 }
        ],

        monthly: [
            { month: "Jan", value: 10 },
            { month: "Feb", value: 20 },
            { month: "Mar", value: 15 }
        ],

        quarterly: [
            { quarter: "Q1", value: 40 },
            { quarter: "Q2", value: 25 },
            { quarter: "Q3", value: 30 }
        ],

        yearly: [
            { year: "2022", value: 50 },
            { year: "2023", value: 70 },
            { year: "2024", value: 60 }
        ],

        tableData: [
            {
                module: "Retail",
                submodule: "Sales",
                load: "Upload",
                template: "Temp1",
                count: 10
            },
            {
                module: "Finance",
                submodule: "Accounts",
                load: "Upload",
                template: "Temp2",
                count: 25
            }
        ]
    };

    this.getView().setModel(new JSONModel(data));

    // Professional chart settings
    this._setChartStyle("idMainChart");
    this._setChartStyle("idPie");
    this._setChartStyle("idMonthly");
    this._setChartStyle("idQuarterly");
    this._setChartStyle("idYearly");
},

_setChartStyle: function (id) {
    var oChart = this.byId(id);
    if (oChart) {
        oChart.setVizProperties({
            plotArea: {
                dataLabel: {
                    visible: true
                }
            },
            valueAxis: {
                title: {
                    visible: false
                }
            },
            categoryAxis: {
                title: {
                    visible: false
                }
            },
            legend: {
                visible: true
            }
        });
    }
}

});
});




.sapMPage {
    background-color: #f7f9fb;
}

.mainContainer {
    padding: 1.5rem;
}

/* Cards */
.sapFCard {
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

/* Titles */
.sapMTitle {
    font-weight: 600;
}

/* Charts */
.sapVizFrame {
    padding: 10px;
}

/* Table */
.sapMTable {
    border-radius: 10px;
}
