<mvc:View controllerName="mfuanalytics.controller.mfureport"  
    xmlns:mvc="sap.ui.core.mvc"  
    xmlns="sap.m"  
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"  
    xmlns:viz.data="sap.viz.ui5.data"  
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">  

<Page title="MFU Dashboard" class="sapBlueHeader">  

<VBox class="mainContainer">  

<!-- FILTER -->
<HBox justifyContent="SpaceBetween" class="filterBar">
    <HBox alignItems="Center">
        <Text text="Module"/>
        <MultiComboBox width="250px"
            selectionFinish="onFilterChange"
            items="{/modules}">
            <core:Item key="{module}" text="{module}" />
        </MultiComboBox>
    </HBox>
</HBox>

<!-- TOP -->
<HBox class="topContainer">  

<VBox width="35%">  

<HBox class="kpiRow">  
<GenericTile header="Total Uploaded" class="tile">  
<TileContent><NumericContent value="{/totalUploaded}"/></TileContent>  
</GenericTile>  

<GenericTile header="Total Approved" class="tile">  
<TileContent><NumericContent value="{/totalApproved}"/></TileContent>  
</GenericTile>  
</HBox>  

<HBox class="kpiRow">  
<GenericTile header="Total Pending" class="tile">  
<TileContent><NumericContent value="{/totalPending}"/></TileContent>  
</GenericTile>  

<GenericTile header="Total Templates" class="tile">  
<TileContent><NumericContent value="{/totalTemplates}"/></TileContent>  
</GenericTile>  
</HBox>  

</VBox>  

<!-- STACKED -->
<Panel width="700px" headerText="MFU Templates by Modules">

<viz:VizFrame vizType="stacked_column" height="320px"
vizProperties='{
"title":{"visible":false},
"plotArea":{"dataLabel":{"visible":true}}
}'>

<viz:dataset>
<viz.data:FlattenedDataset data="{/modules}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}" />
</viz.data:dimensions>

<viz.data:measures>
<viz.data:MeasureDefinition name="Uploaded" value="{uploaded}" />
<viz.data:MeasureDefinition name="Approved" value="{approved}" />
<viz.data:MeasureDefinition name="Pending" value="{pending}" />
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure"
values="Uploaded,Approved,Pending"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension"
values="Module"/>
</viz:feeds>

</viz:VizFrame>
</Panel>  

</HBox>  

<!-- CHART ROW -->
<HBox class="chartRow">

<!-- PIE -->
<VBox class="chartBox">
<Text text="Templates by Count"/>
<viz:VizFrame vizType="pie" height="200px">
<viz:dataset>
<viz.data:FlattenedDataset data="{/pieModules}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Approved" value="{approved}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>
<viz:feeds>
<viz.feeds:FeedItem uid="size" type="Measure" values="Approved"/>
<viz.feeds:FeedItem uid="color" type="Dimension" values="Module"/>
</viz:feeds>
</viz:VizFrame>
</VBox>

<!-- MONTHLY -->
<VBox class="chartBox">
<Text text="Monthly"/>
<viz:VizFrame vizType="column" height="200px">
<viz:dataset>
<viz.data:FlattenedDataset data="{/monthly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Month" value="{month}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>
<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month"/>
</viz:feeds>
</viz:VizFrame>
</VBox>

<!-- QUARTERLY -->
<VBox class="chartBox">
<Text text="Quarterly"/>
<viz:VizFrame vizType="column" height="200px">
<viz:dataset>
<viz.data:FlattenedDataset data="{/quarterly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Quarter" value="{quarter}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>
<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Quarter"/>
</viz:feeds>
</viz:VizFrame>
</VBox>

<!-- YEARLY -->
<VBox class="chartBox">
<Text text="Yearly"/>
<viz:VizFrame vizType="column" height="200px">
<viz:dataset>
<viz.data:FlattenedDataset data="{/yearly}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Year" value="{year}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Value" value="{value}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>
<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Year"/>
</viz:feeds>
</viz:VizFrame>
</VBox>

</HBox>

<!-- TABLE -->
<Panel headerText="MFU Details">
<Table items="{/tableData}">
<columns>
<Column><Text text="Module"/></Column>
<Column><Text text="Sub Module"/></Column>
<Column><Text text="Load Type"/></Column>
<Column><Text text="Template"/></Column>
<Column><Text text="Count"/></Column>
</columns>
<items>
<ColumnListItem>
<cells>
<Text text="{module}"/>
<Text text="{subModule}"/>
<Text text="{loadType}"/>
<Text text="{template}"/>
<Text text="{count}"/>
</cells>
</ColumnListItem>
</items>
</Table>
</Panel>

<!-- ✅ FIXED TREEMAP -->
<Panel headerText="MFU Drill Down">

<viz:VizFrame vizType="treemap" height="400px">

<viz:dataset>
<viz.data:FlattenedDataset data="{/treeData}">

<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}"/>
<viz.data:DimensionDefinition name="Submodule" value="{submodule}"/>
<viz.data:DimensionDefinition name="Template" value="{template}"/>
</viz.data:dimensions>

<viz.data:measures>
<viz.data:MeasureDefinition name="Count" value="{value}"/>
</viz.data:measures>

</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension"
values="Module,Submodule,Template"/>
<viz.feeds:FeedItem uid="size" type="Measure"
values="Count"/>
</viz:feeds>

</viz:VizFrame>

</Panel>

</VBox>  
</Page>  
</mvc:View>






sap.ui.define([
    "sap/ui/core/mvc/Controller",
    "sap/ui/model/json/JSONModel"
], function (Controller, JSONModel) {
    "use strict";

    return Controller.extend("mfuanalytics.controller.mfureport", {

        onInit: function () {

            var data = {

                modules: [
                    { module: "NFRP", uploaded: 45, approved: 30, pending: 10 },
                    { module: "SCBI", uploaded: 70, approved: 50, pending: 15 },
                    { module: "ESG", uploaded: 25, approved: 15, pending: 5 },
                    { module: "ICON", uploaded: 50, approved: 35, pending: 7 }
                ],

                // 👉 PIE (separate to avoid filter issue)
                pieModules: [
                    { module: "NFRP", approved: 30 },
                    { module: "SCBI", approved: 50 },
                    { module: "ESG", approved: 15 },
                    { module: "ICON", approved: 35 }
                ],

                // 👉 MONTHLY
                monthly: [
                    { month: "Jan", value: 10 },
                    { month: "Feb", value: 20 },
                    { month: "Mar", value: 15 }
                ],

                // 👉 QUARTERLY
                quarterly: [
                    { quarter: "Q1", value: 40 },
                    { quarter: "Q2", value: 25 },
                    { quarter: "Q3", value: 30 }
                ],

                // 👉 YEARLY
                yearly: [
                    { year: "2022", value: 50 },
                    { year: "2023", value: 70 },
                    { year: "2024", value: 60 }
                ],

                // 👉 TABLE
                tableData: [
                    { module: "Retail", subModule: "Sales", loadType: "Upload", template: "Temp1", count: 10 },
                    { module: "Finance", subModule: "Accounts", loadType: "Upload", template: "Temp2", count: 25 }
                ],

                // 👉 TREEMAP (FIXED STRUCTURE)
                treeData: [
                    { module: "NFRP", submodule: "Credit Risk", template: "Exposure_Load", value: 1 },
                    { module: "NFRP", submodule: "Liquidity", template: "Liquidity_Load", value: 1 },
                    { module: "SCBI", submodule: "Insurance", template: "Policy_Load", value: 1 },
                    { module: "ICON", submodule: "Capital", template: "Capital_Load", value: 1 }
                ],

                totalUploaded: 190,
                totalApproved: 130,
                totalPending: 37,
                totalTemplates: 4
            };

            // 🔥 STORE ORIGINAL DATA (IMPORTANT)
            this._fullModules = data.modules;
            this._originalTotals = {
                uploaded: 190,
                approved: 130,
                pending: 37,
                templates: 4
            };

            // SET MODEL
            var oModel = new JSONModel(data);
            this.getView().setModel(oModel);
        },

        // 🔥 FILTER LOGIC (MULTI SELECT WORKING)
        onFilterChange: function (oEvent) {

            var selectedKeys = oEvent.getSource().getSelectedKeys();
            var oModel = this.getView().getModel();

            // 👉 If no selection → reset
            if (!selectedKeys || selectedKeys.length === 0) {

                oModel.setProperty("/modules", this._fullModules);

                oModel.setProperty("/totalUploaded", this._originalTotals.uploaded);
                oModel.setProperty("/totalApproved", this._originalTotals.approved);
                oModel.setProperty("/totalPending", this._originalTotals.pending);
                oModel.setProperty("/totalTemplates", this._originalTotals.templates);

                return;
            }

            // 👉 Filter modules
            var filtered = this._fullModules.filter(function (item) {
                return selectedKeys.includes(item.module);
            });

            // 👉 Recalculate KPI
            var totalUploaded = 0;
            var totalApproved = 0;
            var totalPending = 0;

            filtered.forEach(function (item) {
                totalUploaded += item.uploaded;
                totalApproved += item.approved;
                totalPending += item.pending;
            });

            // 👉 Update model safely
            oModel.setProperty("/modules", filtered);
            oModel.setProperty("/totalUploaded", totalUploaded);
            oModel.setProperty("/totalApproved", totalApproved);
            oModel.setProperty("/totalPending", totalPending);
            oModel.setProperty("/totalTemplates", filtered.length);
        }

    });
});
