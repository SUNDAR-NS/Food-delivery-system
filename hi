<mvc:View controllerName="mfuanalytics.controller.mfureport"  
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"  
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"  
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">  

<Page title="MFU Dashboard" class="sapBlueHeader">  

<VBox class="mainContainer">  

<!-- FILTER -->
<Panel class="moduleFilterBox">
<HBox alignItems="Center" justifyContent="SpaceBetween">

<VBox>
<Text text="Module"/>
<MultiComboBox id="moduleFilter"
selectionFinish="onFilterChange"
items="{/allModules}" showClearIcon="true">
<core:Item key="{module}" text="{module}" />
</MultiComboBox>
</VBox>

</HBox>
</Panel>

<!-- KPI + CHART -->
<HBox>  

<VBox width="35%">  

<HBox>  
<GenericTile header="Total Uploaded">  
<TileContent>
<NumericContent value="{/totalUploaded}" icon="sap-icon://upload"/>
</TileContent>  
</GenericTile>  

<GenericTile header="Total Approved">
<TileContent>
<NumericContent value="{/totalApproved}" icon="sap-icon://accept"/>
</TileContent>  
</GenericTile>  
</HBox>  

<HBox>  
<GenericTile header="Total Rejected">  
<TileContent>
<NumericContent value="{/totalRejected}" icon="sap-icon://decline"/>
</TileContent>  
</GenericTile>  

<GenericTile header="Total Templates">  
<TileContent>
<NumericContent value="{/totalTemplates}" icon="sap-icon://document-text"/>
</TileContent>  
</GenericTile>  
</HBox>  

</VBox>  

<!-- CHART -->
<Panel width="700px">

<Toolbar>
<Title text="MFU Templates by Modules"/>
<ToolbarSpacer/>
<Button text="Treemap" press="onToggleChart"/>
</Toolbar>

<VBox id="vizContainer">
<viz:VizFrame id="idVizFrame" vizType="stacked_column" height="320px">

<viz:dataset>
<viz.data:FlattenedDataset data="{/modules}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}" />
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Uploaded" value="{uploaded}" />
<viz.data:MeasureDefinition name="Approved" value="{approved}" />
<viz.data:MeasureDefinition name="Rejected" value="{rejected}" />
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="valueAxis" type="Measure"
values="Uploaded,Approved,Rejected"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension"
values="Module"/>
</viz:feeds>

</viz:VizFrame>
</VBox>

<VBox id="treemapContainer" visible="false">
<core:HTML content="<div id='treemapChart' style='height:320px'></div>" />
</VBox>

</Panel>  

</HBox>  

<!-- PIE + SANKEY -->
<HBox>

<VBox width="50%">
<Text text="Templates by Count"/>
<viz:VizFrame vizType="pie" height="200px">

<viz:dataset>
<viz.data:FlattenedDataset data="{/pieModules}">
<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}"/>
</viz.data:dimensions>
<viz.data:measures>
<viz.data:MeasureDefinition name="Approved" value="{approved}"/>
</viz.data:measures>
</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="size" type="Measure" values="Approved"/>
<viz.feeds:FeedItem uid="color" type="Dimension" values="Module"/>
</viz:feeds>

</viz:VizFrame>
</VBox>

<VBox width="50%">
<Text text="Top MFU Usage"/>
<core:HTML content="<div id='sankeyChart' style='height:200px'></div>" />
</VBox>

</HBox>

<!-- TABLE -->
<Table items="{/tableData}" mode="SingleSelectMaster">

<columns>
<Column><Text text="Module"/></Column>
<Column><Text text="Sub Module"/></Column>
<Column><Text text="Load Type"/></Column>
<Column><Text text="Template"/></Column>
<Column><Text text="Count"/></Column>
</columns>

<items>
<ColumnListItem type="Active" press="onRowPress">
<cells>
<Text text="{module}"/>
<Text text="{subModule}"/>
<Text text="{loadType}"/>
<Text text="{template}"/>
<Text text="{count}"/>
</cells>
</ColumnListItem>
</items>

</Table>

</VBox>  
</Page>  

<!-- DIALOG -->
<Dialog id="templateDialog" title="Template Details">
<content>

<ObjectHeader
title="{detail>/template}"
intro="{detail>/module}"/>

<Table items="{detail>/rows}">
<columns>
<Column><Text text="Property"/></Column>
<Column><Text text="Value"/></Column>
</columns>

<items>
<ColumnListItem>
<cells>
<Text text="{detail>key}"/>
<Text text="{detail>value}"/>
</cells>
</ColumnListItem>
</items>

</Table>

</content>

<endButton>
<Button text="Close" press="onCloseDialog"/>
</endButton>

</Dialog>

</mvc:View>



sap.ui.define([
    "sap/ui/core/mvc/Controller",
    "sap/ui/model/json/JSONModel"
], function (Controller, JSONModel) {
    "use strict";

    return Controller.extend("mfuanalytics.controller.mfureport", {

        onInit: function () {

            this._showTreemap = false;

            var oModel = new JSONModel({
                allModules: [],
                modules: [],
                pieModules: [],
                tableData: [],
                totalUploaded: 0,
                totalApproved: 0,
                totalRejected: 0,
                totalTemplates: 0
            });

            this.getView().setModel(oModel);

            fetch("/odata/v4/mfu/getModules()")
                .then(res => res.json())
                .then(data => {

                    oModel.setProperty("/allModules", data.value);

                    const keys = data.value.map(m => m.module);
                    this.byId("moduleFilter").setSelectedKeys(keys);

                    this.loadDashboard(keys);
                });
        },

        loadDashboard: function (modules) {

            fetch("/odata/v4/mfu/getDashboardData", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ module: modules })
            })
            .then(res => res.json())
            .then(data => {

                var oModel = this.getView().getModel();

                oModel.setProperty("/modules", data.modules || []);
                oModel.setProperty("/pieModules", data.modules || []);
                oModel.setProperty("/tableData", data.table || []);

                oModel.setProperty("/totalUploaded", data.uploaded || 0);
                oModel.setProperty("/totalApproved", data.approved || 0);
                oModel.setProperty("/totalRejected", data.rejected || 0);
                oModel.setProperty("/totalTemplates", data.totalTemplates || 0);

                this._applyChartSettings();

                setTimeout(() => this._renderSankey(), 200);
            });
        },

        onFilterChange: function (oEvent) {
            this.loadDashboard(oEvent.getSource().getSelectedKeys());
        },

        _applyChartSettings: function () {
            var oChart = this.byId("idVizFrame");
            if (oChart) {
                oChart.setVizProperties({
                    plotArea: {
                        colorPalette: ["#0070f2","#107e3e","#bb0000"]
                    }
                });
            }
        },

        onToggleChart: function (oEvent) {

            this._showTreemap = !this._showTreemap;

            this.byId("vizContainer").setVisible(!this._showTreemap);
            this.byId("treemapContainer").setVisible(this._showTreemap);

            oEvent.getSource().setText(this._showTreemap ? "Chart" : "Treemap");

            if (this._showTreemap) {
                setTimeout(() => this._renderTreemap(), 200);
            }
        },

        _renderTreemap: function () {

            var chart = echarts.init(document.getElementById("treemapChart"));

            chart.setOption({
                series: [{
                    type: "treemap",
                    data: [
                        { name: "Approved", value: 100 },
                        { name: "Rejected", value: 40 }
                    ]
                }]
            });

            chart.on("click", (e) => {
                this.getView().setModel(new JSONModel({
                    template: e.name,
                    module: "MFU",
                    rows: [{ key: "Info", value: "Static" }]
                }), "detail");

                this.byId("templateDialog").open();
            });
        },

        _renderSankey: function () {

            var chart = echarts.init(document.getElementById("sankeyChart"));

            chart.setOption({
                series: [{
                    type: "sankey",
                    data: [
                        { name: "Uploaded" },
                        { name: "Approved" },
                        { name: "Rejected" }
                    ],
                    links: [
                        { source: "Uploaded", target: "Approved", value: 50 },
                        { source: "Uploaded", target: "Rejected", value: 20 }
                    ]
                }]
            });
        },

        onRowPress: function (oEvent) {

            var d = oEvent.getSource().getBindingContext().getObject();

            this.getView().setModel(new JSONModel({
                template: d.template,
                module: d.module,
                rows: [{ key: "Count", value: d.count }]
            }), "detail");

            this.byId("templateDialog").open();
        },

        onCloseDialog: function () {
            this.byId("templateDialog").close();
        }

    });
});
