sap.ui.define([
    "sap/ui/core/mvc/Controller",
    "sap/ui/model/json/JSONModel"
], function (Controller, JSONModel) {
    "use strict";

    return Controller.extend("mfuanalytics.controller.mfureport", {

        onInit: function () {

            var data = {

                // 🔥 FULL DATA (WITH USER + DATE)
                allModules: [
                    { module: "NFRP", uploaded: 45, approved: 30, pending: 10, user: "Anand", date: "10D" },
                    { module: "SCBI", uploaded: 70, approved: 50, pending: 15, user: "Sundar", date: "3M" },
                    { module: "ESG", uploaded: 25, approved: 15, pending: 5, user: "Kiran", date: "6M" },
                    { module: "ICON", uploaded: 50, approved: 35, pending: 7, user: "Shivani", date: "1Y" }
                ],

                modules: [],

                // 🔹 STATUS
                statusList: [
                    { key: "uploaded", text: "Uploaded" },
                    { key: "approved", text: "Approved" },
                    { key: "pending", text: "Pending" }
                ],

                // 🔹 USER
                userList: [
                    { key: "Anand", text: "Anand" },
                    { key: "Sundar", text: "Sundar" },
                    { key: "Kiran", text: "Kiran" },
                    { key: "Shivani", text: "Shivani" }
                ],

                // 🔹 DATE
                dateList: [
                    { key: "10D", text: "Last 10 Days" },
                    { key: "3M", text: "Last 3 Months" },
                    { key: "6M", text: "Last 6 Months" },
                    { key: "1Y", text: "Last 1 Year" }
                ],

                totalUploaded: 190,
                totalApproved: 130,
                totalPending: 37,
                totalTemplates: 4
            };

            // INITIAL LOAD
            data.modules = data.allModules;

            this._fullModules = data.allModules;

            var oModel = new JSONModel(data);
            this.getView().setModel(oModel);
        },

        // 🔥 FINAL FILTER (ALL 4 FILTERS USED PROPERLY)
        onFilterChange: function () {

            var oView = this.getView();
            var oModel = oView.getModel();

            var moduleKeys = oView.byId("moduleFilter").getSelectedKeys();
            var statusKeys = oView.byId("statusFilter").getSelectedKeys();
            var userKeys = oView.byId("userFilter").getSelectedKeys();
            var dateKeys = oView.byId("dateFilter").getSelectedKeys();

            var baseData = this._fullModules;

            // ✅ STEP 1: APPLY ALL FILTERS (AND CONDITION)
            var filtered = baseData.filter(item => {

                var moduleMatch = moduleKeys.length === 0 || moduleKeys.includes(item.module);
                var userMatch = userKeys.length === 0 || userKeys.includes(item.user);
                var dateMatch = dateKeys.length === 0 || dateKeys.includes(item.date);

                return moduleMatch && userMatch && dateMatch;
            });

            // ✅ STEP 2: APPLY STATUS FILTER (FOR CHART + KPI)
            var finalData = filtered.map(item => {

                return {
                    module: item.module,
                    uploaded: (statusKeys.length === 0 || statusKeys.includes("uploaded")) ? item.uploaded : 0,
                    approved: (statusKeys.length === 0 || statusKeys.includes("approved")) ? item.approved : 0,
                    pending: (statusKeys.length === 0 || statusKeys.includes("pending")) ? item.pending : 0
                };
            });

            // ✅ STEP 3: KPI CALCULATION
            var totalUploaded = 0,
                totalApproved = 0,
                totalPending = 0;

            finalData.forEach(item => {
                totalUploaded += item.uploaded;
                totalApproved += item.approved;
                totalPending += item.pending;
            });

            // ✅ STEP 4: UPDATE MODEL (DRIVES CHART)
            oModel.setProperty("/modules", finalData);
            oModel.setProperty("/totalUploaded", totalUploaded);
            oModel.setProperty("/totalApproved", totalApproved);
            oModel.setProperty("/totalPending", totalPending);
            oModel.setProperty("/totalTemplates", finalData.length);
        }

    });
});
