<mvc:View controllerName="mfuanalytics.controller.mfureport"  
    xmlns:mvc="sap.ui.core.mvc"  
    xmlns="sap.m"  
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"  
    xmlns:viz.data="sap.viz.ui5.data"  
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">  

<Page title="MFU Dashboard" class="sapBlueHeader">  

<VBox class="mainContainer">  

<!-- 🔥 FILTER BOX -->
<Panel class="moduleFilterBox">
    
    <VBox class="filterContainer">

        <!-- MODULE -->
        <HBox alignItems="Center" class="filterRow">
            <Text text="Module" class="filterLable"/>
            <MultiComboBox
                id="moduleFilter"
                width="200px"
                selectionFinish="onFilterChange"
                items="{/allModules}"
                showClearIcon="true"
                placeholder="Type and select Modules">
                <core:Item key="{module}" text="{module}" />
            </MultiComboBox>
        </HBox>

        <!-- STATUS -->
        <HBox alignItems="Center" class="filterRow">
            <Text text="Status" class="filterLable"/>
            <MultiComboBox
                id="statusFilter"
                width="200px"
                selectionFinish="onFilterChange"
                items="{/statusList}"
                showClearIcon="true"
                placeholder="Select Status">
                <core:Item key="{key}" text="{text}" />
            </MultiComboBox>
        </HBox>

    </VBox>

</Panel>

<!-- 🔥 TOP -->
<HBox class="topContainer">  

    <!-- KPI -->
    <VBox width="35%">  

        <HBox class="kpiRow">  
            <GenericTile header="Total Uploaded" class="tile">  
                <TileContent>
                    <NumericContent value="{/totalUploaded}"/>
                </TileContent>  
            </GenericTile>  

            <GenericTile header="Total Approved" class="tile">  
                <TileContent>
                    <NumericContent value="{/totalApproved}"/>
                </TileContent>  
            </GenericTile>  
        </HBox>  

        <HBox class="kpiRow">  
            <GenericTile header="Total Pending" class="tile">  
                <TileContent>
                    <NumericContent value="{/totalPending}"/>
                </TileContent>  
            </GenericTile>  

            <GenericTile header="Total Templates" class="tile">  
                <TileContent>
                    <NumericContent value="{/totalTemplates}"/>
                </TileContent>  
            </GenericTile>  
        </HBox>  

    </VBox>  

    <!-- STACKED CHART -->
    <Panel width="700px" headerText="MFU Templates by Modules">

        <viz:VizFrame vizType="stacked_column" height="320px" width="100%">
            <viz:dataset>
                <viz.data:FlattenedDataset data="{/modules}">
                    <viz.data:dimensions>
                        <viz.data:DimensionDefinition name="Module" value="{module}" />
                    </viz.data:dimensions>
                    <viz.data:measures>
                        <viz.data:MeasureDefinition name="Uploaded" value="{uploaded}" />
                        <viz.data:MeasureDefinition name="Approved" value="{approved}" />
                        <viz.data:MeasureDefinition name="Pending" value="{pending}" />
                    </viz.data:measures>
                </viz.data:FlattenedDataset>
            </viz:dataset>

            <viz:feeds>
                <viz.feeds:FeedItem uid="valueAxis" type="Measure"
                    values="Uploaded,Approved,Pending"/>
                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension"
                    values="Module"/>
            </viz:feeds>

        </viz:VizFrame>

    </Panel>  

</HBox>  

<!-- 🔥 CHARTS -->
<HBox class="chartRow">

    <!-- PIE -->
    <VBox class="chartBox">
        <Text text="Templates by Count" class="panelTitle"/>
        <viz:VizFrame vizType="pie" height="200px" width="100%">
            <viz:dataset>
                <viz.data:FlattenedDataset data="{/modules}">
                    <viz.data:dimensions>
                        <viz.data:DimensionDefinition name="Module" value="{module}"/>
                    </viz.data:dimensions>
                    <viz.data:measures>
                        <viz.data:MeasureDefinition name="Approved" value="{approved}"/>
                    </viz.data:measures>
                </viz.data:FlattenedDataset>
            </viz:dataset>
            <viz:feeds>
                <viz.feeds:FeedItem uid="size" type="Measure" values="Approved"/>
                <viz.feeds:FeedItem uid="color" type="Dimension" values="Module"/>
            </viz:feeds>
        </viz:VizFrame>
    </VBox>

    <!-- MONTHLY -->
    <VBox class="chartBox">
        <Text text="Monthly" class="panelTitle"/>
        <viz:VizFrame vizType="column" height="200px" width="100%">
            <viz:dataset>
                <viz.data:FlattenedDataset data="{/monthly}">
                    <viz.data:dimensions>
                        <viz.data:DimensionDefinition name="Month" value="{month}"/>
                    </viz.data:dimensions>
                    <viz.data:measures>
                        <viz.data:MeasureDefinition name="Value" value="{value}"/>
                    </viz.data:measures>
                </viz.data:FlattenedDataset>
            </viz:dataset>
            <viz:feeds>
                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month"/>
            </viz:feeds>
        </viz:VizFrame>
    </VBox>

    <!-- QUARTERLY -->
    <VBox class="chartBox">
        <Text text="Quarterly" class="panelTitle"/>
        <viz:VizFrame vizType="column" height="200px" width="100%">
            <viz:dataset>
                <viz.data:FlattenedDataset data="{/quarterly}">
                    <viz.data:dimensions>
                        <viz.data:DimensionDefinition name="Quarter" value="{quarter}"/>
                    </viz.data:dimensions>
                    <viz.data:measures>
                        <viz.data:MeasureDefinition name="Value" value="{value}"/>
                    </viz.data:measures>
                </viz.data:FlattenedDataset>
            </viz:dataset>
            <viz:feeds>
                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Quarter"/>
            </viz:feeds>
        </viz:VizFrame>
    </VBox>

    <!-- YEARLY -->
    <VBox class="chartBox">
        <Text text="Yearly" class="panelTitle"/>
        <viz:VizFrame vizType="column" height="200px" width="100%">
            <viz:dataset>
                <viz.data:FlattenedDataset data="{/yearly}">
                    <viz.data:dimensions>
                        <viz.data:DimensionDefinition name="Year" value="{year}"/>
                    </viz.data:dimensions>
                    <viz.data:measures>
                        <viz.data:MeasureDefinition name="Value" value="{value}"/>
                    </viz.data:measures>
                </viz.data:FlattenedDataset>
            </viz:dataset>
            <viz:feeds>
                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value"/>
                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Year"/>
            </viz:feeds>
        </viz:VizFrame>
    </VBox>

</HBox>

<!-- TABLE -->
<Panel headerText="MFU Details" class="sapUiMediumMarginTop">
    <Table items="{/tableData}">
        <columns>
            <Column><Text text="Module"/></Column>
            <Column><Text text="Sub Module"/></Column>
            <Column><Text text="Load Type"/></Column>
            <Column><Text text="Template"/></Column>
            <Column><Text text="Count"/></Column>
        </columns>
        <items>
            <ColumnListItem>
                <cells>
                    <Text text="{module}"/>
                    <Text text="{subModule}"/>
                    <Text text="{loadType}"/>
                    <Text text="{template}"/>
                    <Text text="{count}"/>
                </cells>
            </ColumnListItem>
        </items>
    </Table>
</Panel>

</VBox>  
</Page>  
</mvc:View>





sap.ui.define([
    "sap/ui/core/mvc/Controller",
    "sap/ui/model/json/JSONModel"
], function (Controller, JSONModel) {
    "use strict";

    return Controller.extend("mfuanalytics.controller.mfureport", {

        onInit: function () {

            var data = {

                allModules: [
                    { module: "NFRP", uploaded: 45, approved: 30, pending: 10 },
                    { module: "SCBI", uploaded: 70, approved: 50, pending: 15 },
                    { module: "ESG", uploaded: 25, approved: 15, pending: 5 },
                    { module: "ICON", uploaded: 50, approved: 35, pending: 7 }
                ],

                modules: [],

                statusList: [
                    { key: "uploaded", text: "Uploaded" },
                    { key: "approved", text: "Approved" },
                    { key: "pending", text: "Pending" }
                ],

                monthly: [
                    { month: "Jan", value: 10 },
                    { month: "Feb", value: 20 },
                    { month: "Mar", value: 15 }
                ],

                quarterly: [
                    { quarter: "Q1", value: 40 },
                    { quarter: "Q2", value: 25 },
                    { quarter: "Q3", value: 30 }
                ],

                yearly: [
                    { year: "2022", value: 50 },
                    { year: "2023", value: 70 },
                    { year: "2024", value: 60 }
                ],

                tableData: [
                    { module: "NFRP", subModule: "Mapping master", loadType: "Upload", template: "Temp1", count: 10 },
                    { module: "SCBI", subModule: "Config master", loadType: "Truncate", template: "Temp2", count: 25 }
                ],

                totalUploaded: 190,
                totalApproved: 130,
                totalPending: 37,
                totalTemplates: 4
            };

            data.modules = data.allModules;

            this._fullModules = data.allModules;

            var oModel = new JSONModel(data);
            this.getView().setModel(oModel);
        },

        onFilterChange: function () {

            var oView = this.getView();
            var oModel = oView.getModel();

            var moduleKeys = oView.byId("moduleFilter").getSelectedKeys();
            var statusKeys = oView.byId("statusFilter").getSelectedKeys();

            var data = this._fullModules;

            if (moduleKeys.length > 0) {
                data = data.filter(item =>
                    moduleKeys.includes(item.module)
                );
            }

            var totalUploaded = 0,
                totalApproved = 0,
                totalPending = 0;

            data.forEach(item => {

                if (statusKeys.length === 0 || statusKeys.includes("uploaded")) {
                    totalUploaded += item.uploaded;
                }

                if (statusKeys.length === 0 || statusKeys.includes("approved")) {
                    totalApproved += item.approved;
                }

                if (statusKeys.length === 0 || statusKeys.includes("pending")) {
                    totalPending += item.pending;
                }
            });

            oModel.setProperty("/modules", data);
            oModel.setProperty("/totalUploaded", totalUploaded);
            oModel.setProperty("/totalApproved", totalApproved);
            oModel.setProperty("/totalPending", totalPending);
            oModel.setProperty("/totalTemplates", data.length);
        }

    });
});
