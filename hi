                                        value: 6,
                                        meta: {
                                            user: "John Miller",
                                            created: "14-Feb-2026",
                                            approved: "-",
                                            module: "SCBI",
                                            submodule: "Customer",
                                            status: "Pending"
                                        }
                                    }
                                ]
                            }
                        ]
                    },

                    {
                        name: "ICON",
                        children: [
                            {
                                name: "Approved",
                                children: [
                                    {
                                        name: "ICON_INVOICE_UPLOAD",
                                        value: 9,
                                        meta: {
