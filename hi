<mvc:View
    controllerName="mfuanalytics.controller.mfureport"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
>
    <Page
        id="_IDGenPage"
        title="MFU Dashboard"
        class="sapHeader"
    >
        <VBox
            id="_IDGenVBox"
            class="mainContainer"
        >
            <Panel
                id="_IDGenPanel2"
                class="moduleFilterBox"
            >
                <VBox
                    id="_IDGenVBox6"
                    class="filterContainer"
                >
                    <HBox
                        id="_IDGenHBox"
                        alignItems="Center"
                        class="filterRow"
                    >
                        <Text
                            id="_IDGenText"
                            text="Module"
                            class="filterLable"
                        />
                        <MultiComboBox
                            id="_IDGenMultiComboBox1"
                            width="210px"
                            selectionFinish="onFilterChange"
                            items="{/allModules}"
                            showClearIcon="true"
                        >
                            <core:Item
                                id="_IDGenItem"
                                key="{module}"
                                text="{module}"
                            />
                        </MultiComboBox>
                    </HBox>
                </VBox>
            </Panel>

            <HBox
                id="_IDGenHBox3"
                class="topContainer"
            >
                <VBox
                    id="_IDGenVBox1"
                    width="35%"
                >
                    <HBox
                        id="_IDGenHBox4"
                        class="kpiRow"
                    >
                        <GenericTile
                            id="_IDGenGenericTile"
                            header="Total Uploaded"
                            class="tile"
                            press="onUploadedTilePress"
                        >
                            <customData>
                                <core:CustomData
                                    key="type"
                                    value="uploaded"
                                />
                            </customData>
                            <TileContent id="_IDGenTileContent">
                                <NumericContent
                                    id="_IDGenNumericContent"
                                    value="{/totalUploaded}"
                                    icon="sap-icon://upload"
                                    valueColor="None"
                                />
                            </TileContent>
                        </GenericTile>
                        <GenericTile
                            id="_IDGenGenericTile1"
                            header="Total Approved"
                            class="tile"
                            press="onApprovedPress"
                        >
                            <customData>
                                <core:CustomData
                                    key="type"
                                    value="approved"
                                />
                            </customData>
                            <TileContent id="_IDGenTileContent1">
                                <NumericContent
                                    id="_IDGenNumericContent1"
                                    value="{/totalApproved}"
                                    icon="sap-icon://accept"
                                    valueColor="Good"
                                />
                            </TileContent>
                        </GenericTile>
                    </HBox>
                    <HBox
                        id="_IDGenHBox5"
                        class="kpiRow"
                    >
                        <GenericTile
                            id="_IDGenGenericTile2"
                            header="Total Rejected"
                            class="tile"
                            press="onRejectedTilePress"
                        >
                            <customData>
                                <core:CustomData
                                    key="type"
                                    value="rejected"
                                />
                            </customData>
                            <TileContent id="_IDGenTileContent2">
                                <NumericContent
                                    id="_IDGenNumericContent2"
                                    value="{/totalRejected}"
                                    icon="sap-icon://decline"
                                    valueColor="Critical"
                                />
                            </TileContent>
                        </GenericTile>
                        <GenericTile
                            id="_IDGenGenericTile3"
                            header="Total Templates"
                            class="tile"
                            press="onTotalTilePress"
                        >
                            <customData>
                                <core:CustomData
                                    key="type"
                                    value="total"
                                />
                            </customData>
                            <TileContent id="_IDGenTileContent3">
                                <NumericContent
                                    id="_IDGenNumericContent3"
                                    value="{/totalTemplates}"
                                    icon="sap-icon://document-text"
                                    valueColor="Neutral"
                                />
                            </TileContent>
                        </GenericTile>
                    </HBox>
                </VBox>
                <Panel
                    id="_IDGenPanel"
                    width="800px"
                >
                    <Toolbar class="panelTitle">
                        <Title text="MFU Templates by Modules" />
                        <ToolbarSpacer />
                        <Button
                            text="Treemap"
                            icon="sap-icon://switch-views"
                            press="onToggleChart"
                        />
                    </Toolbar>
                    <VBox
                        id="vizContainer"
                        visible="true"
                    >
                        <viz:VizFrame
                            id="_IDGenVizFrame"
                            vizType="stacked_column"
                            height="320px"
                            width="100%"
                            vizProperties='{
                                "title": { "visible": false },
                                "legend": {
                                "visible": true,
                                "position":"right"
                                },
                                "plotArea": {
                                    "dataLabel": { 
                                        "visible": false,
                                        "showTotal": true
                                    },
                                    "dataLabelTotal": {
                                        "visible": true
                                    },
                                    
                                    "drawingEffect": "glossy",
                                    "colorPalette":[
                                        "#0a6ed1",
                                        "#107e3e",
                                        "#e9730c"
                                    ],
                                    "animation":{
                                    "dataLoading":true
                                    }
                                },
                                "valueAxis":{
                                "title":{"visible":true}
                                },
                                "categoryAxis":{
                                "title":{"visible":true}
                                },
                                "interaction": {
                                    "selectability": {
                                        "mode": "MULTIPLE"
                                    }
                                }
                            }'
                        >
                            <viz:dataset>
                                <viz.data:FlattenedDataset
                                    id="_IDGenFlattenedDataset"
                                    data="{/modules}"
                                >
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition
                                            id="_IDGenDimensionDefinition"
                                            name="Module"
                                            value="{module}"
                                        />
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition
                                            id="_IDGenMeasureDefinition"
                                            name="Uploaded"
                                            value="{uploaded}"
                                        />
                                        <viz.data:MeasureDefinition
                                            id="_IDGenMeasureDefinition1"
                                            name="Approved"
                                            value="{approved}"
                                        />
                                        <viz.data:MeasureDefinition
                                            id="_IDGenMeasureDefinition2"
                                            name="Rejected"
                                            value="{rejected}"
                                        />
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem
                                    id="_IDGenFeedItem"
                                    uid="valueAxis"
                                    type="Measure"
                                    values="Uploaded,Approved,Rejected"
                                />
                                <viz.feeds:FeedItem
                                    id="_IDGenFeedItem1"
                                    uid="categoryAxis"
                                    type="Dimension"
                                    values="Module"
                                />
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>
                    <VBox
                        id="treemapContainer"
                        visible="false"
                    >
                        <core:HTML
                            content="&lt;div id='treemapChart' style='width:100%;height:320px'&gt;&lt;/div&gt;"
                        />
                    </VBox>
                </Panel>
            </HBox>

            <HBox
                id="_IDGenHBox6"
                class="chartRow"
            >
                <VBox
                    id="_IDGenVBox2"
                    class="chartBox"
                >
                    <Text
                        id="_IDGenText1"
                        text="Templates by Count"
                        class="panelTitle"
                    />
                    <viz:VizFrame
    id="_IDGenVizFrame1"
    vizType="donut"
    height="230px"
    width="100%"
    vizProperties='{
        "title": { "visible": false },

        "legend": {
            "visible": true,
            "position": "right"
        },

        "plotArea": {
            "innerRadius": "60%",
            "dataLabel": {
                "visible": true,
                "type": "percentage"
            }
        },

        "interaction": {
            "selectability": {
                "mode": "SINGLE"
            }
        }
    }'
>

    <viz:dataset>
        <viz.data:FlattenedDataset data="{path:'/getPieData()',parameters: { $$operationMode: 'Server'}}">

            <!-- 🔥 USER -->
            <viz.data:dimensions>
                <viz.data:DimensionDefinition
                    name="User"
                    value="{user}" />
            </viz.data:dimensions>

            <!-- 🔥 COUNT -->
            <viz.data:measures>
                <viz.data:MeasureDefinition
                    name="Templates"
                    value="{count}" />
            </viz.data:measures>

        </viz.data:FlattenedDataset>
    </viz:dataset>

    <viz:feeds>
        <!-- SIZE -->
        <viz.feeds:FeedItem
            uid="size"
            type="Measure"
            values="Templates"/>

        <!-- COLOR -->
        <viz.feeds:FeedItem
            uid="color"
            type="Dimension"
            values="User"/>
    </viz:feeds>

</viz:VizFrame>
                </VBox>
                <VBox
                    id="_IDGenVBox7"
                    class="chartBox"
                >
                    <Text
                        id="_IDGenText99"
                        text="Top MFU Usage"
                        class="panelTitle"
                    />
                    <core:HTML
                        id="sankeyHtml"
                        content="&lt;div id='sankeyChart' style='width:800px;height:200px'&gt;&lt;/div&gt;"
                    />
                </VBox>
            </HBox>

            <Panel
                id="_IDGenPanel1"
                class="sapUiMediumMarginTop mfuTablePanel"
            >
                <Toolbar class="panelTitle">
                    <Title text="MFU Details" />
                    <ToolbarSpacer />
                </Toolbar>

                <!-- 🔥 SCROLLABLE BOX -->
                <ScrollContainer
                    height="300px"
                    vertical="true"
                    class="tableScrollBox"
                >
                    <Table
                        id="_IDGenTable"
                        items="{/tableData}"
                        width="100%"
                        sticky="ColumnHeaders"
                    >
                        <columns>
                            <Column>
                                <Text text="Module" />
                            </Column>
                            <Column>
                                <Text text="Sub Module" />
                            </Column>
                            <Column>
                                <Text text="Load Type" />
                            </Column>
                            <Column>
                                <Text text="Template" />
                            </Column>
                            <Column>
                                <Text text="Load Count" />
                            </Column>
                        </columns>

                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{module}" />
                                    <Text text="{subModule}" />
                                    <Text text="{loadType}" />
                                    <Text text="{template}" />
                                    <Text text="{count}" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </ScrollContainer>
            </Panel>
        </VBox>
    </Page>

    <Dialog
        id="templateDialog"
        contentWidth="600px"
        contentHeight="auto"
        draggable="true"
        resizable="true"
        title="Template Details"
    >
        <content>
            <ObjectHeader
                title="{detail>/template}"
                number="{detail>/status}"
                numberState="{detail>/statusState}"
                intro="{detail>/module}"
                icon="sap-icon://document-text"
            >
                <attributes>
                    <ObjectAttribute
                        title="User"
                        text="{detail>/user}"
                    />
                    <ObjectAttribute
                        title="SubModule"
                        text="{detail>/submodule}"
                    />
                </attributes>
            </ObjectHeader>
            <Table
                inset="false"
                class="sapUiSmallMarginTop"
                items="{detail>/rows}"
            >
                <columns>
                    <Column>
                        <Text text="Property" />
                    </Column>
                    <Column>
                        <Text text="Value" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{detail>key}" />
                            <Text text="{detail>value}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <endButton>
            <Button
                text="Close"
                type="Emphasized"
                press=".onCloseDialog"
            />
        </endButton>
    </Dialog>
</mvc:View>




sap.ui.define([
    "sap/ui/core/mvc/Controller",
    "sap/ui/model/json/JSONModel"
], function (Controller, JSONModel) {
    "use strict";

    return Controller.extend("mfuanalytics.controller.mfureport", {

        onInit: function () {

            this._showTreemap = false;

            var oModel = new JSONModel({
                allModules: [],
                modules: [],
                tableData: [],
                totalUploaded: 0,
                totalApproved: 0,
                totalRejected: 0,
                totalTemplates: 0
            });

            this.getView().setModel(oModel);

            setTimeout(() => {
                document.activeElement.blur();
            }, 100);

            // 🔥 LOAD MODULES
            fetch("/odata/v4/mfu/getModules()")
                .then(res => res.json())
                .then(data => {

                    oModel.setProperty("/allModules", data.value);

                    const allKeys = data.value.map(m => m.module);

                    this.byId("_IDGenMultiComboBox1").setSelectedKeys(allKeys);

                    this.loadDashboard(allKeys);
                });
        },

        // =========================
        // 🔁 TREEMAP TOGGLE
        // =========================
        onToggleChart: function (oEvent) {

            this._showTreemap = !this._showTreemap;

            this.byId("vizContainer").setVisible(!this._showTreemap);
            this.byId("treemapContainer").setVisible(this._showTreemap);

            oEvent.getSource().setText(
                this._showTreemap ? "Chart" : "Treemap"
            );

            if (this._showTreemap) {
                setTimeout(this._renderTreemap.bind(this), 200);
            }
        },

        // =========================
        // 🌳 TREEMAP (STATIC)
        // =========================
        _renderTreemap: function () {

            var treemapDom = document.getElementById("treemapChart");

            if (!treemapDom) return;

            var treemapChart = echarts.init(treemapDom);

            var option = {
                tooltip: { formatter: '{b}' },
                series: [{
                    type: "treemap",
                    nodeClick: "zoomToNode",
                    leafDepth: 1,
                    breadcrumb: { show: true },
                    label: { show: true, formatter: "{b}" },
                    data: [
                        {
                            name: "NFRP",
                            children: [
                                {
                                    name: "Approved",
                                    children: [
                                        { name: "MFU_BUD_AIEA_AIBL", value: 12 },
                                        { name: "MFU_FPNA_CIB_FY", value: 8 }
                                    ]
                                },
                                {
                                    name: "Pending",
                                    children: [
                                        { name: "MFU_ENTITY_XLATE", value: 5 }
                                    ]
                                },
                                {
                                    name: "Rejected",
                                    children: [
                                        { name: "MFU_CONFIG_TARGET_SETTING", value: 3 }
                                    ]
                                }
                            ]
                        }
                    ]
                }]
            };

            treemapChart.setOption(option);
        },

        onCloseDialog: function () {
            this.byId("templateDialog").close();
        },

        // =========================
        // 🔥 SANKEY
        // =========================
        onAfterRendering: function () {
            this.loadSankey();
        },

        loadSankey: function () {

            fetch("/odata/v4/mfu/getSankeyData()")
                .then(res => res.json())
                .then(data => {

                    const result = data.value || [];

                    if (result.length === 0) return;

                    const nodeSet = new Set();
                    const links = [];

                    result.forEach(r => {

                        nodeSet.add(r.period);
                        nodeSet.add(r.module);

                        links.push({
                            source: r.period,
                            target: r.module,
                            value: r.value
                        });

                        (r.templates || []).forEach(t => {

                            nodeSet.add(t.name);

                            links.push({
                                source: r.module,
                                target: t.name,
                                value: t.value
                            });

                        });
                    });

                    const nodes = Array.from(nodeSet).map(n => ({ name: n }));

                    var chartDom = document.getElementById("sankeyChart");

                    if (!chartDom) return;

                    var chart = echarts.init(chartDom);

                    chart.setOption({
                        tooltip: { trigger: "item" },
                        series: [{
                            type: "sankey",
                            nodeAlign: "left",
                            data: nodes,
                            links: links,
                            lineStyle: { curveness: 0.5 },
                            emphasis: { focus: "adjacency" }
                        }]
                    });

                })
                .catch(err => {
                    console.error("SANKEY ERROR:", err);
                });
        },

        // =========================
        // 🔍 FILTER
        // =========================
        onFilterChange: function (oEvent) {

            const keys = oEvent.getSource().getSelectedKeys();

            if (!keys || keys.length === 0) {
                this.loadDashboard([]);
            } else {
                this.loadDashboard(keys);
            }
        },

        // =========================
        // 📊 DASHBOARD
        // =========================
        loadDashboard: function (modules) {

            fetch("/odata/v4/mfu/getDashboardData", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ module: modules })
            })
            .then(res => res.json())
            .then(data => {

                var oModel = this.getView().getModel();

                oModel.setProperty("/modules", data.modules || []);
                oModel.setProperty("/tableData", data.table || []);
                oModel.setProperty("/totalUploaded", data.uploaded || 0);
                oModel.setProperty("/totalApproved", data.approved || 0);
                oModel.setProperty("/totalRejected", data.rejected || 0);
                oModel.setProperty("/totalTemplates", data.totalTemplates || 0);
            })
            .catch(err => {
                console.error("API ERROR:", err);
            });
        },

        // =========================
        // 📦 DIALOGS
        // =========================
        onCloseUploadDialog: function () {
            this._uploadedDialog.close();
        },

        onUploadedTilePress: async function () {

            var modules = this.byId("_IDGenMultiComboBox1").getSelectedKeys();

            if (!this._uploadedDialog) {
                this._uploadedDialog = await this.loadFragment({
                    name: "mfuanalytics.view.fragments.uploaded"
                });
                this.getView().addDependent(this._uploadedDialog);
            }

            fetch("/odata/v4/mfu/getDashboardData", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ module: modules })
            })
            .then(res => res.json())
            .then(data => {

                var oJson = new sap.ui.model.json.JSONModel({
                    items: data.uploadedmodules
                });

                this._uploadedDialog.setModel(oJson, "uploaded");
                this._uploadedDialog.open();
            });
        },

        onCloseTileDialog: function () {
            this._approvedDialog.close();
        },

        onApprovedPress: async function () {

            var modules = this.byId("_IDGenMultiComboBox1").getSelectedKeys();

            if (!this._approvedDialog) {
                this._approvedDialog = await this.loadFragment({
                    name: "mfuanalytics.view.fragments.approved"
                });
                this.getView().addDependent(this._approvedDialog);
            }

            fetch("/odata/v4/mfu/getDashboardData", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ module: modules })
            })
            .then(res => res.json())
            .then(data => {

                var oJson = new sap.ui.model.json.JSONModel({
                    items: data.approvedmodules
                });

                this._approvedDialog.setModel(oJson, "approved");
                this._approvedDialog.open();
            });
        }

    });
});
