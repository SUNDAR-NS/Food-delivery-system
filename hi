/* 🔥 STRONG TABLE GRID BORDERS */

/* Table outer border */
.sapMListTbl {
    border: 1px solid #c8c8c8;
    border-radius: 6px;
}

/* Header cells */
.sapMListTblHeaderCell {
    border: 1px solid #c8c8c8 !important;
    background-color: #f4f6f8;
    font-weight: 600;
    text-align: center;
}

/* Data cells */
.sapMListTblCell {
    border: 1px solid #e0e0e0 !important;
    text-align: center;
}

/* Row hover */
.sapMListTblRow:hover {
    background-color: #eaf4ff;
}

/* Zebra rows */
.sapMListTblRow:nth-child(even) {
    background-color: #fafafa;
}
