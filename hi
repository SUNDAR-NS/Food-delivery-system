<Panel headerText="MFU Drill Down">

<viz:VizFrame vizType="treemap" height="400px"
vizProperties='{
"title":{"visible":false},
"plotArea":{"dataLabel":{"visible":true}}
}'>

<viz:dataset>
<viz.data:FlattenedDataset data="{/treeData}">

<viz.data:dimensions>
<viz.data:DimensionDefinition name="Module" value="{module}"/>
<viz.data:DimensionDefinition name="Submodule" value="{submodule}"/>
</viz.data:dimensions>

<viz.data:measures>
<viz.data:MeasureDefinition name="Count" value="{value}"/>
</viz.data:measures>

</viz.data:FlattenedDataset>
</viz:dataset>

<viz:feeds>
<viz.feeds:FeedItem uid="categoryAxis"
type="Dimension"
values="Module,Submodule"/>

<viz.feeds:FeedItem uid="size"
type="Measure"
values="Count"/>

</viz:feeds>

</viz:VizFrame>

</Panel>




treeData: [
{ module: "NFRP", submodule: "Credit Risk", value: 1 },
{ module: "NFRP", submodule: "Liquidity", value: 1 },
{ module: "SCBI", submodule: "Insurance", value: 1 },
{ module: "ICON", submodule: "Capital", value: 1 }
]
