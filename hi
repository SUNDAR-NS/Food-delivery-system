                                children: [
                                    {
                                        name: "NFRP_PAYMENT_V1",
                                        value: 12,
                                        meta: {
                                            user: "Rahul Sharma",
                                            created: "12-Feb-2026",
                                            approved: "13-Feb-2026",
                                            module: "NFRP",
                                            submodule: "Payments",
                                            status: "Approved"
                                        }
                                    },
                                    {
                                        name: "NFRP_VENDOR_UPLOAD",
                                        value: 8,
                                        meta: {
